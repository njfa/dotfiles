#!/bin/bash

# スクリプトのディレクトリから PROJECT_ROOT を決定
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# コンテナランナースクリプトのパスを設定
CR_SCRIPT="${CR_SCRIPT:-$HOME/.dotfiles/bin/container-runner}"

# 必要なコマンドの確認
check_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "エラー: 必要なコマンド '$1' が見つかりません。" >&2
        echo "インストールしてから再試行してください。" >&2
        return 1
    fi
    return 0
}

# 必須コマンドのチェック
check_dependencies() {
    local missing_deps=0

    for cmd in docker yq jq; do
        if ! check_command "$cmd"; then
            missing_deps=$((missing_deps + 1))
        fi
    done

    if [ $missing_deps -gt 0 ]; then
        echo "エラー: 依存関係が満たされていません。必要なパッケージをインストールしてください。" >&2
        exit 1
    fi
}

# 依存関係チェック
check_dependencies

# コンテナランナースクリプトの読み込み
if [[ -f "$CR_SCRIPT" ]]; then
    # スクリプトを読み込む
    . "$CR_SCRIPT"
else
    echo "エラー: コンテナランナースクリプトが見つかりません: $CR_SCRIPT" >&2
    echo "環境変数 CR_SCRIPT を設定するか、デフォルトの場所にスクリプトを配置してください。" >&2
    exit 1
fi

# カラー定義（既存のものに追加）
FRAME_COLOR='\033[1;32m'  # 鮮やかな緑色
DIMMED='\033[2m'          # テキストを暗く表示
INFO_COLOR='\033[1;37m'   # 情報表示用のシアン色
UPDATE_COLOR='\033[1;34m' # 更新表示用の黄色

# パスを人間が読みやすい形式に変換する関数
format_path() {
    local path="$1"
    # $HOMEパスを~に置き換える
    if [[ "$path" == "$HOME"* ]]; then
        echo "~${path#$HOME}"
    else
        echo "$path"
    fi
}

# AWS CLIを使用してリージョンを取得する関数
get_aws_region_from_profile() {
    local profile="$1"

    # プロファイルが指定されている場合は--profileオプションを使用
    local aws_cmd="aws configure get region"
    if [ -n "$profile" ] && [ "$profile" != "default" ]; then
        aws_cmd="aws configure get region --profile $profile"
    fi

    # AWS CLIを使用してリージョンを取得
    local region=""
    if command -v aws >/dev/null 2>&1; then
        region=$($aws_cmd 2>/dev/null | tr -d '\n\r')
    fi

    echo "$region"
}

# Claude Codeのバージョンを取得する関数
get_claude_version() {
    local docker_image="$1"

    if [ "$docker_image" != "unknown" ] && docker image inspect "$docker_image" >/dev/null 2>&1; then
        local version=$(docker run --rm "$docker_image" npm list -g @anthropic-ai/claude-code --json 2>/dev/null | jq -r '.dependencies."@anthropic-ai/claude-code".version' 2>/dev/null)
        if [ -z "$version" ] || [ "$version" = "null" ]; then
            echo "unknown"
        else
            echo "$version"
        fi
    else
        echo "unknown"
    fi
}

# 最新のClaude Codeバージョンを取得する関数
get_latest_claude_version() {
    local latest_version=$(npm view @anthropic-ai/claude-code version 2>/dev/null)
    if [ -z "$latest_version" ]; then
        echo "unknown"
    else
        echo "$latest_version"
    fi
}

# 認証情報と設定ファイルのパスを含むロゴを表示する関数
print_logo() {
    local credential_path="$1"
    local config_path="$2"
    local use_bedrock="$3"
    local aws_config_path="$4"
    local compose_path="$5"
    local service="$6"
    local claude_version="$7"
    local latest_version="$8"
    shift 8
    local mount_info=("$@")

    # 各行の内容を配列に格納（動的な枠幅を計算するため）
    local lines=()
    local max_length=0

    # タイトル行
    local title_line="✻ Claude Code Container (ccc)"
    lines+=("$title_line")
    if [ ${#title_line} -gt $max_length ]; then
        max_length=${#title_line}
    fi

    # 空行（計算不要）
    lines+=("")

    # バージョン行の内容を構築
    local version_line="Claude Code Version: $claude_version"
    if [ "$claude_version" != "unknown" ] && [ "$latest_version" != "unknown" ]; then
        if [ "$claude_version" = "$latest_version" ]; then
            version_line="${version_line} ✓"
        else
            version_line="${version_line} (latest: $latest_version)"
        fi
    fi
    lines+=("$version_line")
    # バージョン行の実際の長さを計算（エスケープシーケンスを除く）
    local version_display_length
    if [ "$claude_version" != "unknown" ] && [ "$latest_version" != "unknown" ]; then
        if [ "$claude_version" = "$latest_version" ]; then
            version_display_length=$((${#claude_version} + 23)) # "Claude Code Version: " + version + " ✓"
        else
            version_display_length=$((${#claude_version} + ${#latest_version} + 32)) # 全体の長さ
        fi
    else
        version_display_length=$((${#claude_version} + 21)) # "Claude Code Version: " + version
    fi
    if [ $version_display_length -gt $max_length ]; then
        max_length=$version_display_length
    fi

    # プロバイダー行
    local provider_line
    if [ "$use_bedrock" = true ]; then
        provider_line="Provider: AWS Bedrock"
    else
        provider_line="Provider: Anthropic"
    fi
    lines+=("$provider_line")
    if [ ${#provider_line} -gt $max_length ]; then
        max_length=${#provider_line}
    fi

    # 区切り線（特殊処理）
    lines+=("---separator---")

    # Anthropicの場合
    if [ "$use_bedrock" != true ]; then
        # Anthropicの場合の認証情報
        local cred_basename=$(format_path "$credential_path")
        local conf_basename=$(format_path "$config_path")

        local cred_line="Credential: $cred_basename"
        lines+=("$cred_line")
        if [ ${#cred_line} -gt $max_length ]; then
            max_length=${#cred_line}
        fi

        local conf_line="Config: $conf_basename"
        lines+=("$conf_line")
        if [ ${#conf_line} -gt $max_length ]; then
            max_length=${#conf_line}
        fi
    else
        # Bedrockの場合のAWS設定情報
        # AWS環境変数が設定されている場合はそれを表示
        local aws_config_info=""
        if [ -n "$AWS_CONFIG_FILE" ]; then
            aws_config_info=$(format_path "$AWS_CONFIG_FILE")
        elif [ -n "$AWS_SHARED_CREDENTIALS_FILE" ]; then
            aws_config_info=$(format_path "$(dirname "$AWS_SHARED_CREDENTIALS_FILE")")
        else
            aws_config_info="~/.aws"
        fi

        local aws_conf_line="AWS Config: $aws_config_info"
        lines+=("$aws_conf_line")
        if [ ${#aws_conf_line} -gt $max_length ]; then
            max_length=${#aws_conf_line}
        fi

        # AWS認証情報
        local auth_method=""
        if [ -n "$bedrock_profile" ]; then
            auth_method="Profile: $bedrock_profile"
        else
            auth_method="Default Credentials"
        fi
        local auth_line="AWS Auth: $auth_method"
        lines+=("$auth_line")
        if [ ${#auth_line} -gt $max_length ]; then
            max_length=${#auth_line}
        fi

        # AWSリージョン（優先順位に従って決定）
        local region_text=""
        local region_source=""

        if [ -n "$bedrock_region" ]; then
            # 1. --bedrock-regionで指定された値
            region_text="$bedrock_region"
            region_source=" (specified)"
        else
            # 2. AWS CLIから読み込む
            local config_region=$(get_aws_region_from_profile "$bedrock_profile")
            if [ -n "$config_region" ]; then
                region_text="$config_region"
                if [ -n "$bedrock_profile" ] && [ "$bedrock_profile" != "default" ]; then
                    region_source=" (profile: $bedrock_profile)"
                else
                    region_source=" (config)"
                fi
            fi
        fi

        # リージョンが未設定の場合
        if [ -z "$region_text" ]; then
            region_text="not set"
            region_source=""
        fi

        region_text="${region_text}${region_source}"
        local region_line="AWS Region: $region_text"
        lines+=("$region_line")
        if [ ${#region_line} -gt $max_length ]; then
            max_length=${#region_line}
        fi

        # CA証明書バンドル
        if [ -n "$bedrock_ca_bundle" ]; then
            local ca_bundle_basename=$(format_path "$bedrock_ca_bundle")
            local ca_line="CA Bundle: $ca_bundle_basename"
            lines+=("$ca_line")
            if [ ${#ca_line} -gt $max_length ]; then
                max_length=${#ca_line}
            fi
        fi
    fi

    # モデル表示（Bedrock/Anthropic共通）
    local model_display=""
    local model_label="Model"

    # コマンドライン引数から取得したモデル
    if [ -n "$model" ]; then
        model_display="$model"
    # compose.ymlのenvironmentセクションから取得
    elif [ -f "$compose_path" ]; then
        local compose_model=$(yq eval '.services.claude-code.environment.ANTHROPIC_MODEL // ""' "$compose_path" 2>/dev/null)
        if [ -n "$compose_model" ] && [ "$compose_model" != "null" ]; then
            model_display="$compose_model (compose.yml)"
        fi
    fi

    # 高速モデル表示（Bedrock/Anthropic共通）
    local fast_model_display=""
    local fast_model_label="Fast Model"

    # コマンドライン引数から取得した高速モデル
    if [ -n "$fast_model" ]; then
        fast_model_display="$fast_model"
    # compose.ymlのenvironmentセクションから取得
    elif [ -f "$compose_path" ]; then
        local compose_fast_model=$(yq eval '.services.claude-code.environment.ANTHROPIC_SMALL_FAST_MODEL // ""' "$compose_path" 2>/dev/null)
        if [ -n "$compose_fast_model" ] && [ "$compose_fast_model" != "null" ]; then
            fast_model_display="$compose_fast_model (compose.yml)"
        fi
    fi

    # モデルが設定されている場合は表示
    if [ -n "$model_display" ]; then
        local model_line="$model_label: $model_display"
        lines+=("$model_line")
        if [ ${#model_line} -gt $max_length ]; then
            max_length=${#model_line}
        fi
    fi

    # 高速モデルが設定されている場合は表示
    if [ -n "$fast_model_display" ]; then
        local fast_model_line="$fast_model_label: $fast_model_display"
        lines+=("$fast_model_line")
        if [ ${#fast_model_line} -gt $max_length ]; then
            max_length=${#fast_model_line}
        fi
    fi

    # プロンプトキャッシュ
    local caching_status="Enabled"
    if [ "$disable_caching" = true ]; then
        caching_status="Disabled"
    fi
    local cache_line="Prompt Cache: $caching_status"
    lines+=("$cache_line")
    if [ ${#cache_line} -gt $max_length ]; then
        max_length=${#cache_line}
    fi

    # マウント情報の処理
    if [ ${#mount_info[@]} -gt 0 ]; then
        lines+=("---separator---")
        local mount_header="Mount Paths:"
        lines+=("$mount_header")
        if [ ${#mount_header} -gt $max_length ]; then
            max_length=${#mount_header}
        fi

        for mount_item in "${mount_info[@]}"; do
            local mount_line="  $mount_item"
            lines+=("$mount_line")
            if [ ${#mount_line} -gt $max_length ]; then
                max_length=${#mount_line}
            fi
        done
    fi

    # 動的な枠幅を計算（左右のパディングとインデント分を追加）
    # インデント（3スペース）+ 内容 + 余裕（3スペース）
    local frame_width=$((max_length + 6))

    # 横線を作成する関数
    create_horizontal_line() {
        local char="$1"
        local line=""
        for ((i = 0; i < frame_width; i++)); do
            line="${line}${char}"
        done
        echo "$line"
    }

    # 上部の枠線
    echo -e "${FRAME_COLOR}╭$(create_horizontal_line "─")╮${NC}"

    # 配列から各行を表示
    local line_index=0
    for line_content in "${lines[@]}"; do
        if [ "$line_content" = "" ]; then
            # 空行
            echo -e "${FRAME_COLOR}│$(printf '%*s' $((frame_width)) '')│${NC}"
        elif [ "$line_content" = "---separator---" ]; then
            # 区切り線
            echo -e "${FRAME_COLOR}│${DIMMED}$(create_horizontal_line "─")${NC}${FRAME_COLOR}│${NC}"
        else
            # 通常の行
            # タイトル行の特別処理
            if [ $line_index -eq 0 ]; then
                echo -e "${FRAME_COLOR}│ ${NC}${GREEN}✻${NC} ${line_content:2}$(printf '%*s' $((frame_width - ${#line_content} - 2)) '') ${FRAME_COLOR}│${NC}"
            # バージョン行の特別処理（色付き）
            elif [[ "$line_content" == "Claude Code Version:"* ]]; then
                local version_base="Claude Code Version: $claude_version"
                local padding_needed=$((frame_width - ${#version_base} - 4))

                if [ "$claude_version" != "unknown" ] && [ "$latest_version" != "unknown" ]; then
                    if [ "$claude_version" = "$latest_version" ]; then
                        echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Claude Code Version:${NC} $claude_version ${GREEN}✓${NC}$(printf '%*s' $((padding_needed - 2)) '') ${FRAME_COLOR}│${NC}"
                    else
                        local latest_part=" (latest: $latest_version)"
                        padding_needed=$((frame_width - ${#version_base} - ${#latest_part} - 4))
                        echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Claude Code Version:${NC} $claude_version ${UPDATE_COLOR}(latest: $latest_version)${NC}$(printf '%*s' $padding_needed '') ${FRAME_COLOR}│${NC}"
                    fi
                else
                    echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Claude Code Version:${NC} $claude_version$(printf '%*s' $padding_needed '') ${FRAME_COLOR}│${NC}"
                fi
            # プロバイダー行の特別処理（Bedrock時は色付き）
            elif [[ "$line_content" == "Provider:"* ]]; then
                if [ "$use_bedrock" = true ]; then
                    echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Provider:${NC} ${UPDATE_COLOR}AWS Bedrock${NC}$(printf '%*s' $((frame_width - 25)) '') ${FRAME_COLOR}│${NC}"
                else
                    echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Provider:${NC} Anthropic$(printf '%*s' $((frame_width - 23)) '') ${FRAME_COLOR}│${NC}"
                fi
            # Mount Pathsヘッダーの特別処理
            elif [[ "$line_content" = "Mount Paths:" ]]; then
                echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}${line_content}${NC}$(printf '%*s' $((frame_width - ${#line_content} - 4)) '') ${FRAME_COLOR}│${NC}"
            # その他の情報行（色付きラベル）
            elif [[ "$line_content" == "Credential:"* ]] || [[ "$line_content" == "Config:"* ]] ||
                [[ "$line_content" == "AWS Config:"* ]] || [[ "$line_content" == "AWS Auth:"* ]] ||
                [[ "$line_content" == "AWS Region:"* ]] || [[ "$line_content" == "Model:"* ]] ||
                [[ "$line_content" == "Fast Model:"* ]] || [[ "$line_content" == "CA Bundle:"* ]] || [[ "$line_content" == "Prompt Cache:"* ]]; then
                # ラベルと値を分離
                local label="${line_content%%:*}:"
                local value="${line_content#*: }"
                echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}${label}${NC} ${value}$(printf '%*s' $((frame_width - ${#line_content} - 4)) '') ${FRAME_COLOR}│${NC}"
            # マウントパスのインデント行
            elif [[ "$line_content" == "  "* ]]; then
                # パスが長すぎる場合は省略
                local formatted_line="$line_content"
                # local max_path_length=$((frame_width - 7))
                # if [ ${#formatted_line} -gt ${max_path_length} ]; then
                #     # 先頭の空白を保持しながら省略
                #     formatted_line="     ...${line_content: -$((max_path_length - 8))}"
                # fi
                echo -e "${FRAME_COLOR}│${NC}   ${formatted_line}$(printf '%*s' $((frame_width - ${#formatted_line} - 4)) '') ${FRAME_COLOR}│${NC}"
            else
                # その他の通常行
                echo -e "${FRAME_COLOR}│${NC}   ${line_content}$(printf '%*s' $((frame_width - ${#line_content} - 4)) '') ${FRAME_COLOR}│${NC}"
            fi
        fi
        ((line_index++))
    done

    # 下部の枠線
    echo -e "${FRAME_COLOR}╰$(create_horizontal_line "─")╯${NC}"
    echo
}

# MCP設定ビルド関数
process_mcp_build() {
    local mcp_servers=("$@")

    if [ ${#mcp_servers[@]} -eq 0 ]; then
        log_error "MCPサーバー名を指定してください"
        log_info "使用法: $(basename "$0") mcp-build <MCPサーバー名>..."
        return 1
    fi

    # 検索ディレクトリの設定（優先順位順）
    local search_dirs=(
        "./.claude/mcp"     # プロジェクトディレクトリ
        "$HOME/.claude/mcp" # ユーザーディレクトリ
    )

    # 統合用のJSONオブジェクト
    local merged_json="{\"mcpServers\":{}}"
    local found_servers=()

    log_info "MCPサーバー設定をビルド中..."

    # 各MCPサーバーを処理
    for server_name in "${mcp_servers[@]}"; do
        local server_found=false
        local json_file="${server_name}.json"

        # 優先順位順でJSONファイルを検索
        for search_dir in "${search_dirs[@]}"; do
            local file_path="${search_dir}/${json_file}"

            if [ -f "$file_path" ]; then
                log_info "見つかりました: $file_path"

                # JSONファイルの妥当性をチェック
                if ! jq empty "$file_path" >/dev/null 2>&1; then
                    log_error "無効なJSONファイル: $file_path"
                    return 1
                fi

                # JSONファイルの内容を読み込み
                local server_config=$(cat "$file_path")

                # mcpServersオブジェクトにマージ
                merged_json=$(echo "$merged_json" | jq --argjson config "$server_config" '.mcpServers += $config')
                if [ $? -ne 0 ]; then
                    log_error "JSON設定のマージに失敗しました: $file_path"
                    return 1
                fi

                found_servers+=("$server_name")
                server_found=true
                break # 最初に見つかったファイルを使用
            fi
        done

        # サーバーが見つからない場合は警告
        if [ "$server_found" = false ]; then
            log_warning "MCPサーバー設定が見つかりません: ${json_file}"
            log_info "検索パス: ${search_dirs[*]}"
        fi
    done

    # 見つかったサーバーがない場合はエラー
    if [ ${#found_servers[@]} -eq 0 ]; then
        log_error "指定されたMCPサーバー設定が見つかりませんでした"
        return 1
    fi

    # プロジェクトルートの.mcp.jsonに出力
    local output_file="./.mcp.json"
    echo "$merged_json" | jq . >"$output_file"

    if [ $? -eq 0 ]; then
        log_success ".mcp.jsonを作成しました"
        log_info "統合されたMCPサーバー: ${found_servers[*]}"
        log_info "出力先: $output_file"

        # 作成されたファイルの内容を表示（オプション）
        if [ "$quiet" = false ]; then
            echo
            echo "=== 作成された.mcp.json ==="
            jq . "$output_file"
            echo "=========================="
        fi
    else
        log_error ".mcp.jsonの作成に失敗しました"
        return 1
    fi

    return 0
}

# Claudeイメージの更新関数
update_claude_image() {
    local use_cache="$1"
    log_info "Claudeイメージを更新中..."

    local build_args=()

    # use_cacheフラグをチェック
    if [ "$use_cache" = "use_cache" ]; then
        log_info "キャッシュを使用してビルドします"
    else
        log_info "キャッシュを無効化してビルドします"
        build_args+=("--no-cache")
    fi

    # イメージの再ビルド
    if ! docker compose -f "$PROJECT_ROOT/compose.yml" build "${build_args[@]}" claude-code; then
        log_error "イメージの更新に失敗しました"
        return 1
    fi

    log_success "Claudeイメージが正常に更新されました"
    return 0
}

# メイン関数
ccc_main() {
    # デフォルト値の設定
    local source_paths=()
    local compose_path="$PROJECT_ROOT/compose.yml"
    local service="claude-code"
    local remove_orphans=true # デフォルトでオーファンコンテナを削除する
    local claude_credential_path="$HOME/.claude"
    local claude_config_path="$HOME/.claude.json"
    local command_args=("claude")     # デフォルトのコマンド
    local show_logo=true              # デフォルトでロゴを表示
    local show_info=false             # デフォルトで設定情報を表示
    local show_separator=false        # デフォルトでセパレータを表示
    local quiet=true                  # デフォルトは静かモード
    local workdir="/workspace"        # 作業ディレクトリ (--workdir)
    local source_path_specified=false # ソースパスが指定されたかどうかのフラグ
    local use_bedrock=false           # Bedrock使用フラグ
    local bedrock_region=""           # Bedrockリージョン
    local bedrock_profile=""          # AWS プロファイル
    local bedrock_ca_bundle=""        # AWS CA証明書バンドルパス
    local disable_caching=false       # プロンプトキャッシュ無効化フラグ
    local model=""                    # Anthropicモデル
    local fast_model=""               # Anthropicの高速な小型モデル
    local docker_log_level=""         # Dockerログレベル
    local container_user=""           # コンテナ実行ユーザー
    local -a persistent_env_vars=()   # 永続的に設定する環境変数
    local block_outbound=false        # アウトバウンド通信ブロックフラグ
    local exclusive_edit_mode=false   # 排他的編集モードフラグ

    # オプションと引数の解析
    while [[ $# -gt 0 ]]; do
        case $1 in
        -s | --source-path)
            source_paths+=("$2")
            source_path_specified=true
            shift 2
            ;;
        --compose-path)
            compose_path="$2"
            shift 2
            ;;
        -S | --service)
            service="$2"
            shift 2
            ;;
        --config-dir-path)
            claude_credential_path="$2"
            shift 2
            ;;
        --config-file-path)
            claude_config_path="$2"
            shift 2
            ;;
        --bedrock-profile)
            bedrock_profile="$2"
            shift 2
            ;;
        --bedrock-region)
            bedrock_region="$2"
            shift 2
            ;;
        --bedrock-ca-bundle)
            bedrock_ca_bundle="$2"
            shift 2
            ;;
        --disable-caching)
            disable_caching=true
            shift
            ;;
        --model)
            model="$2"
            shift 2
            ;;
        --fast-model)
            fast_model="$2"
            shift 2
            ;;
        --workdir)
            workdir="$2"
            shift 2
            ;;
        --no-rm-orphans)
            remove_orphans=false
            shift
            ;;
        --no-logo)
            show_logo=false
            shift
            ;;
        --info)
            show_info=true
            shift
            ;;
        --separator)
            show_separator=true
            shift
            ;;
        --bedrock)
            use_bedrock=true
            # --bedrockオプションはccc専用でClaudeコマンドには渡さない
            shift
            ;;
        --log-level)
            docker_log_level="$2"
            shift 2
            ;;
        --user)
            container_user="$2"
            shift 2
            ;;
        -v | --verbose)
            quiet=false
            shift
            ;;
        --set-env)
            # KEY=VALUE形式で環境変数を永続的に設定
            if [ $# -gt 1 ] && [[ "$2" == *"="* ]]; then
                persistent_env_vars+=("$2")
                shift 2
            else
                log_error "--set-envにはKEY=VALUE形式の引数が必要です"
                return 1
            fi
            ;;
        -h | --help)
            # Claudeのヘルプを表示するか、cccのヘルプを表示するか判断
            if [ ${#command_args[@]} -eq 1 ]; then
                # 他にClaudeオプションがない場合はcccのヘルプを表示
                show_ccc_help
                return 0
            else
                # 他にClaudeオプションがある場合はClaudeに渡す
                command_args+=("$1")
                shift
            fi
            ;;
        --claude-help)
            # Claudeのヘルプを表示
            command_args=("claude" "--help")
            shift
            ;;
        --block-outbound)
            # アウトバウンド通信をブロック
            block_outbound=true
            shift
            ;;
        --exclusive-edit-mode)
            # 最初に編集したコードの種類（プロダクトコードまたはテストコード）に応じて、
            # 後続の編集を同じ種類のコードのみに制限する
            exclusive_edit_mode=true
            shift
            ;;
        build)
            # buildサブコマンドが指定された場合
            shift
            local build_use_cache=false

            # buildサブコマンドの引数を解析
            while [[ $# -gt 0 ]]; do
                case $1 in
                --use-cache)
                    build_use_cache=true
                    shift
                    ;;
                -h | --help)
                    echo "使用法: $(basename "$0") build [オプション]"
                    echo ""
                    echo "Claudeコンテナイメージをビルドします。"
                    echo ""
                    echo "オプション:"
                    echo "  --use-cache    ビルド時にキャッシュを使用する（デフォルト：キャッシュ無効）"
                    echo "  -h, --help     このヘルプメッセージを表示"
                    return 0
                    ;;
                *)
                    log_error "不明なオプション: $1"
                    echo "使用法: $(basename "$0") build [--use-cache]"
                    return 1
                    ;;
                esac
            done

            # ビルド処理を実行して終了
            if [ "$build_use_cache" = true ]; then
                update_claude_image "use_cache"
            else
                update_claude_image
            fi
            return $?
            ;;
        mcp)
            # mcpサブコマンドが指定された場合
            shift
            # 最初の引数がbuildかチェック
            if [ $# -gt 0 ] && [ "$1" = "build" ]; then
                # mcp buildの場合は従来のmcp-build処理を実行
                shift
                process_mcp_build "$@"
                return $?
            else
                # それ以外はすべてClaude Codeに委譲
                command_args=("claude" "mcp" "$@")
                break
            fi
            ;;
        deploy-claude-md)
            # deploy-claude-mdサブコマンドが指定された場合
            shift
            local source_dir="$HOME/.claude"
            local target_file="CLAUDE.md"

            # ソースディレクトリの存在確認
            if [ ! -d "$source_dir" ]; then
                log_error "ディレクトリが存在しません: $source_dir"
                return 1
            fi

            # CLAUDE_*.md形式のファイルを検索
            local claude_files=()
            while IFS= read -r -d '' file; do
                claude_files+=("$file")
            done < <(find "$source_dir" -maxdepth 1 -name "CLAUDE_*.md" -type f -print0 | sort -z)

            if [ ${#claude_files[@]} -eq 0 ]; then
                log_error "$source_dir にCLAUDE_*.md形式のファイルが見つかりません"
                return 1
            fi

            local selected_file=""

            # fzfが利用可能か確認
            if command -v fzf >/dev/null 2>&1; then
                # fzfを使用してファイルを選択
                selected_file=$(printf '%s\n' "${claude_files[@]}" | fzf --prompt="配置するCLAUDE.mdファイルを選択: " --height=40% --reverse)

                # fzfでキャンセルされた場合
                if [ -z "$selected_file" ]; then
                    log_info "選択がキャンセルされました"
                    return 0
                fi
            else
                # fzfが利用できない場合は番号選択
                log_info "利用可能なCLAUDE_*.mdファイル:"
                echo
                for i in "${!claude_files[@]}"; do
                    local filename=$(basename "${claude_files[$i]}")
                    # CLAUDE_プレフィックスと.md拡張子を除去して表示
                    local display_name="${filename#CLAUDE_}"
                    display_name="${display_name%.md}"
                    printf "  %2d) %s\n" $((i + 1)) "$display_name"
                done
                echo

                # 選択を促す
                local selection
                while true; do
                    read -p "配置するファイルの番号を入力してください (1-${#claude_files[@]}, 0でキャンセル): " selection

                    # 入力が数字かチェック
                    if [[ ! "$selection" =~ ^[0-9]+$ ]]; then
                        log_error "数字を入力してください"
                        continue
                    fi

                    # キャンセル
                    if [ "$selection" -eq 0 ]; then
                        log_info "選択がキャンセルされました"
                        return 0
                    fi

                    # 範囲チェック
                    if [ "$selection" -ge 1 ] && [ "$selection" -le ${#claude_files[@]} ]; then
                        selected_file="${claude_files[$((selection - 1))]}"
                        break
                    else
                        log_error "1から${#claude_files[@]}の範囲で入力してください"
                    fi
                done
            fi

            # 既存のCLAUDE.mdが存在する場合は退避
            if [ -f "$target_file" ]; then
                local backup_file="CLAUDE.$(date +%Y%m%d_%H%M%S).md"
                log_info "既存のCLAUDE.mdを退避しています: $backup_file"
                if ! mv "$target_file" "$backup_file"; then
                    log_error "CLAUDE.mdの退避に失敗しました"
                    return 1
                fi
                log_success "CLAUDE.mdを退避しました: $backup_file"
            fi

            # ファイルをコピー
            local selected_basename=$(basename "$selected_file")
            log_info "$selected_basename をCLAUDE.mdとして配置しています..."
            if ! cp "$selected_file" "$target_file"; then
                log_error "ファイルのコピーに失敗しました"
                return 1
            fi

            log_success "CLAUDE.mdを配置しました"
            log_info "配置元: $selected_file"
            log_info "配置先: $(pwd)/$target_file"
            return 0
            ;;
        --)
            shift
            # "--" 以降の引数があればそれをコマンドとして使用
            if [ $# -gt 0 ]; then
                command_args=("$@")
            fi
            break
            ;;
        -*)
            # その他のオプションはClaudeに渡す
            if [ $# -gt 1 ] && [[ "$2" != -* ]]; then
                # 値を持つオプションの場合
                command_args+=("$1" "$2")
                shift 2
            else
                # フラグオプションの場合
                command_args+=("$1")
                shift
            fi
            ;;
        *)
            # オプション以外の引数もClaudeに渡す
            command_args+=("$1")
            shift
            ;;
        esac
    done

    # 永続的な環境変数の設定が要求された場合
    if [ ${#persistent_env_vars[@]} -gt 0 ]; then
        log_info "compose.ymlに環境変数を永続的に設定しています..."

        # compose.ymlの存在確認
        if [ ! -f "$compose_path" ]; then
            log_error "指定されたComposeファイル '$compose_path' が見つかりません。"
            return 1
        fi

        # 各環境変数を追加
        for env_var in "${persistent_env_vars[@]}"; do
            # KEY=VALUEの形式を分解
            local key="${env_var%%=*}"
            local value="${env_var#*=}"

            # yqを使って環境変数を追加または更新
            if ! yq eval ".services.claude-code.environment.$key = \"$value\"" -i "$compose_path" 2>/dev/null; then
                log_error "環境変数の永続的な設定に失敗しました: $key=$value"
                return 1
            fi

            log_success "環境変数を設定しました: $key=$value"
        done

        log_info "compose.ymlが更新されました。"
        return 0
    fi

    # source_pathsが空の場合は現在のディレクトリを使用
    if [ ${#source_paths[@]} -eq 0 ]; then
        source_paths=($(pwd))
    fi

    # マウント情報を保存する配列（表示用）
    local mount_info_display=()

    # 認証情報ディレクトリの存在確認と作成
    if [ ! -d "$claude_credential_path" ]; then
        log_info "認証情報ディレクトリ '$claude_credential_path' が見つかりません。作成します。"
        mkdir -p "$claude_credential_path" || {
            log_error "認証情報ディレクトリの作成に失敗しました: $claude_credential_path"
            return 1
        }
        log_success "認証情報ディレクトリを作成しました: $claude_credential_path"
    fi

    # uvキャッシュディレクトリの存在確認と作成
    local uv_cache_dir="$HOME/.cache/uv"
    if [ ! -d "$uv_cache_dir" ]; then
        log_info "uvキャッシュディレクトリ '$uv_cache_dir' が見つかりません。作成します。"
        mkdir -p "$uv_cache_dir" || {
            log_error "uvキャッシュディレクトリの作成に失敗しました: $uv_cache_dir"
            return 1
        }
        log_success "uvキャッシュディレクトリを作成しました: $uv_cache_dir"
    fi

    # .serenaディレクトリの存在確認と作成
    local serena_dir="./.serena"
    if [ ! -d "$serena_dir" ]; then
        log_info "Serenaディレクトリ '$serena_dir' が見つかりません。作成します。"
        mkdir -p "$serena_dir" || {
            log_error "Serenaディレクトリの作成に失敗しました: $serena_dir"
            return 1
        }
        log_success "Serenaディレクトリを作成しました: $serena_dir"
    fi

    # 設定ファイルの存在確認と作成
    if [ ! -f "$claude_config_path" ]; then
        log_info "設定ファイル '$claude_config_path' が見つかりません。作成します。"
        echo -n "Claude Code設定ファイルの内容を入力してください (Enterで空のJSONを使用): "
        read -r config_content </dev/tty

        # 入力がない場合は空のJSONオブジェクトを使用
        if [ -z "$config_content" ]; then
            config_content="{}"
        fi

        # JSONの妥当性を検証
        if ! echo "$config_content" | jq . >/dev/null 2>&1; then
            log_error "入力されたJSONが無効です。空のJSONオブジェクトを使用します。"
            config_content="{}"
        fi

        # ファイルに書き込み
        echo "$config_content" >"$claude_config_path" || {
            log_error "設定ファイルの作成に失敗しました: $claude_config_path"
            return 1
        }
        log_success "設定ファイルを作成しました: $claude_config_path"
    fi

    # Bedrock使用時の初期チェック
    if [ "$use_bedrock" = true ]; then
        # AWS CLIが利用可能かチェック
        if ! command -v aws >/dev/null 2>&1; then
            log_error "AWS CLIが見つかりません。AWS CLIをインストールしてください。"
            return 1
        fi

        # AWS設定ファイルの確認（AWS環境変数が設定されていない場合のみ）
        if [ -z "$AWS_CONFIG_FILE" ] && [ -z "$AWS_SHARED_CREDENTIALS_FILE" ]; then
            local default_aws_dir="$HOME/.aws"
            if [ ! -d "$default_aws_dir" ] || [ ! -f "$default_aws_dir/config" ]; then
                log_info "AWS設定ファイルが見つかりません。AWS設定を行います。"

                # プロファイルオプションの設定
                local aws_configure_cmd="aws configure"
                if [ -n "$bedrock_profile" ]; then
                    aws_configure_cmd="aws configure --profile $bedrock_profile"
                    log_info "プロファイル '$bedrock_profile' で設定を行います。"
                fi

                # aws configureを実行
                if ! $aws_configure_cmd; then
                    log_error "AWS設定に失敗しました。"
                    return 1
                fi

                log_success "AWS設定が完了しました。"
            fi
        fi
    fi

    # 環境変数を準備
    # env_vars: Dockerデーモンに渡す環境変数
    local env_vars=(
        "PROJECT_ROOT=$PROJECT_ROOT"
        "CLAUDE_CREDENTIAL_PATH=$claude_credential_path"
        "CLAUDE_CONFIG_PATH=$claude_config_path"
    )

    # container_env_vars: コンテナ内で読み込む環境変数（compose.ymlのenvironmentに追加）
    local container_env_vars=(
        "WORKING_DIR=$workdir"
    )

    # Bedrock使用時の環境変数設定
    # 優先順位: 環境変数 > AWS config/credential
    # AWS SDKは環境変数を優先的に使用するため、環境変数が設定されている場合は
    # AWS config/credentialファイルの内容より環境変数の値が使用される
    if [ "$use_bedrock" = true ]; then
        # CLAUDE_CODE_USE_BEDROCKを設定
        container_env_vars+=("CLAUDE_CODE_USE_BEDROCK=1")

        # プロファイルが指定されている場合
        if [ -n "$bedrock_profile" ]; then
            container_env_vars+=("AWS_PROFILE=$bedrock_profile")
        fi

        # リージョンの設定（優先順位に従って）
        local resolved_region=""

        # 1. --bedrock-regionで指定された値が最優先
        if [ -n "$bedrock_region" ]; then
            resolved_region="$bedrock_region"
        else
            # 2. AWS CLIからリージョンを読み込む
            resolved_region=$(get_aws_region_from_profile "$bedrock_profile")
        fi

        # リージョンが決定された場合は環境変数に設定
        if [ -n "$resolved_region" ]; then
            container_env_vars+=("AWS_REGION=$resolved_region")
        fi

        # CA証明書バンドルが指定されている場合
        if [ -n "$bedrock_ca_bundle" ]; then
            container_env_vars+=("AWS_CA_BUNDLE=$bedrock_ca_bundle")
        fi

        # AWS_BEARER_TOKEN_BEDROCK環境変数が設定されている場合はコンテナに渡す
        if [ -n "$AWS_BEARER_TOKEN_BEDROCK" ]; then
            container_env_vars+=("AWS_BEARER_TOKEN_BEDROCK=$AWS_BEARER_TOKEN_BEDROCK")
        fi
    fi

    # プロンプトキャッシュ無効化フラグ（Anthropic APIでも使用可能）
    if [ "$disable_caching" = true ]; then
        container_env_vars+=("DISABLE_PROMPT_CACHING=1")
    fi

    # モデル指定がある場合
    if [ -n "$model" ]; then
        container_env_vars+=("ANTHROPIC_MODEL=$model")
    fi

    # 高速モデル指定がある場合
    if [ -n "$fast_model" ]; then
        container_env_vars+=("ANTHROPIC_SMALL_FAST_MODEL=$fast_model")
    fi

    # 排他的編集モードが有効な場合
    if [ "$exclusive_edit_mode" = true ]; then
        container_env_vars+=("CLAUDE_OPERATION_TYPE_VALIDATION=true")
    fi

    # タイムゾーン情報を取得して設定
    local tz
    if command -v timedatectl >/dev/null 2>&1; then
        tz=$(timedatectl | grep "Time zone" | awk '{print $3}')
        if [ -n "$tz" ]; then
            env_vars+=("TZ=$tz")
        fi
    fi

    # SOURCE_PATH環境変数は-sオプションが指定されていない場合のみ設定
    if [ "$source_path_specified" = false ]; then
        env_vars+=("SOURCE_PATH=${source_paths[0]}")
    fi

    # 一時ファイルの作成
    local temp_compose_file=$(mktemp)

    # composeファイルのコピーと存在確認
    if [ ! -f "$compose_path" ]; then
        log_error "指定されたComposeファイル '$compose_path' が見つかりません。"
        return 1
    fi

    cp "$compose_path" "$temp_compose_file" || {
        log_error "Composeファイルのコピーに失敗しました: $compose_path"
        return 1
    }

    # ユーザーが-s/--source-pathを指定した場合、デフォルトのマウント設定を削除
    if [ "$source_path_specified" = true ]; then
        if ! yq eval 'del(.services.claude-code.volumes[] | select(.target == "/workspace/"))' -i "$temp_compose_file" 2>/dev/null; then
            log_error "yqコマンドの実行に失敗しました。yqが正しくインストールされているか確認してください。"
            rm -f "$temp_compose_file"
            return 1
        fi
    fi

    # ソースパスが指定されている場合、マウント設定を追加
    if [ "$source_path_specified" = true ]; then
        # 各ソースパスの存在確認と正規化
        local normalized_paths=()
        for src_path in "${source_paths[@]}"; do
            # パスを絶対パスに正規化
            local abs_path=$(realpath "$src_path" 2>/dev/null)
            if [ -z "$abs_path" ] || [ ! -d "$abs_path" ]; then
                log_error "指定されたソースパス '$src_path' が存在しないか、ディレクトリではありません。"
                rm -f "$temp_compose_file"
                return 1
            fi
            normalized_paths+=("$abs_path")
        done
        # 正規化されたパスを使用
        source_paths=("${normalized_paths[@]}")

        # 既に使用されているマウント先ディレクトリ名を追跡
        declare -A target_dirs

        # ソースパスが1つの場合は直接 /workspace/ にマウント
        if [ ${#source_paths[@]} -eq 1 ]; then
            local src_path="${source_paths[0]}"
            if ! yq eval ".services.claude-code.volumes += [{\"type\": \"bind\", \"source\": \"$src_path\", \"target\": \"/workspace/\"}]" -i "$temp_compose_file" 2>/dev/null; then
                log_error "マウント設定の追加に失敗しました: $src_path"
                rm -f "$temp_compose_file"
                return 1
            fi
            # 表示用情報を記録
            mount_info_display+=("$(format_path "$src_path") → /workspace/")
        else
            # ソースパスが複数の場合は、すべてbasename形式でマウント
            for ((i = 0; i < ${#source_paths[@]}; i++)); do
                local src_path="${source_paths[$i]}"
                local dir_name=$(basename "$src_path")
                local target_name="$dir_name"
                local counter=1

                # ディレクトリ名が重複する場合、連番を付与
                while [[ ${target_dirs[$target_name]} ]]; do
                    target_name="${dir_name}-${counter}"
                    ((counter++))
                done

                # 使用したディレクトリ名を記録
                target_dirs[$target_name]=1
                local target_path="/workspace/$target_name"

                # yqを使って新しいマウントポイントを追加
                if ! yq eval ".services.claude-code.volumes += [{\"type\": \"bind\", \"source\": \"$src_path\", \"target\": \"$target_path\"}]" -i "$temp_compose_file" 2>/dev/null; then
                    log_error "マウント設定の追加に失敗しました: $src_path -> $target_path"
                    rm -f "$temp_compose_file"
                    return 1
                fi
                # 表示用情報を記録
                mount_info_display+=("$(format_path "$src_path") → $target_path")
            done
        fi
    else
        # source_pathが指定されていない場合のデフォルトマウント情報
        mount_info_display+=("$(format_path "${source_paths[0]}") → /workspace/")
    fi

    # Bedrock使用時のAWS設定ファイルのマウント設定
    if [ "$use_bedrock" = true ]; then
        # AWS環境変数が設定されている場合は個別にマウント
        if [ -n "$AWS_CONFIG_FILE" ] || [ -n "$AWS_SHARED_CREDENTIALS_FILE" ]; then
            # AWS_CONFIG_FILEが設定されている場合
            if [ -n "$AWS_CONFIG_FILE" ] && [ -f "$AWS_CONFIG_FILE" ]; then
                local config_source=$(realpath "$AWS_CONFIG_FILE")
                local config_target="/home/node/.aws/config"
                if ! yq eval ".services.claude-code.volumes += [{\"type\": \"bind\", \"source\": \"$config_source\", \"target\": \"$config_target\"}]" -i "$temp_compose_file" 2>/dev/null; then
                    log_error "AWS設定ファイルのマウント設定の追加に失敗しました: $config_source"
                    rm -f "$temp_compose_file"
                    return 1
                fi
                log_info "AWS設定ファイルをマウント: $config_source -> $config_target"
                # 表示用情報を記録
                mount_info_display+=("$(format_path "$config_source") → $config_target")
            fi

            # AWS_SHARED_CREDENTIALS_FILEが設定されている場合
            if [ -n "$AWS_SHARED_CREDENTIALS_FILE" ] && [ -f "$AWS_SHARED_CREDENTIALS_FILE" ]; then
                local credentials_source=$(realpath "$AWS_SHARED_CREDENTIALS_FILE")
                local credentials_target="/home/node/.aws/credentials"
                if ! yq eval ".services.claude-code.volumes += [{\"type\": \"bind\", \"source\": \"$credentials_source\", \"target\": \"$credentials_target\"}]" -i "$temp_compose_file" 2>/dev/null; then
                    log_error "AWS認証情報ファイルのマウント設定の追加に失敗しました: $credentials_source"
                    rm -f "$temp_compose_file"
                    return 1
                fi
                log_info "AWS認証情報ファイルをマウント: $credentials_source -> $credentials_target"
                # 表示用情報を記録
                mount_info_display+=("$(format_path "$credentials_source") → $credentials_target")
            fi
        else
            # デフォルトの ~/.aws ディレクトリをマウント
            local default_aws_dir="$HOME/.aws"
            if [ -d "$default_aws_dir" ]; then
                if ! yq eval ".services.claude-code.volumes += [{\"type\": \"bind\", \"source\": \"$default_aws_dir\", \"target\": \"/home/node/.aws\"}]" -i "$temp_compose_file" 2>/dev/null; then
                    log_error "AWS設定ディレクトリのマウント設定の追加に失敗しました: $default_aws_dir"
                    rm -f "$temp_compose_file"
                    return 1
                fi
                # 表示用情報を記録
                mount_info_display+=("$(format_path "$default_aws_dir") → /home/node/.aws")
            fi
        fi
    fi

    # 常にマウントされる固定パスを追加
    mount_info_display+=("$(format_path "$claude_credential_path") → /home/node/.claude")
    mount_info_display+=("$(format_path "$claude_config_path") → /home/node/.claude.json")
    mount_info_display+=("$(format_path "$uv_cache_dir") → /usr/local/share/uv-cache")

    # --dangerously-skip-permissionsが指定されていて--block-outboundが指定されていない場合に警告
    if [ "$has_skip_permissions" = true ] && [ "$block_outbound" = false ]; then
        log_warning "--dangerously-skip-permissionsが指定されています。"
        log_warning "セキュリティのため、--block-outboundオプションの使用を推奨します。"
        echo
    fi

    # --block-outboundが指定されている場合（--dangerously-skip-permissionsの有無に関わらず）
    if [ "$block_outbound" = true ]; then
        log_info "プロキシ経由でアウトバウンド通信を制限します..."

        # コンテナにプロキシ設定を追加（大文字・小文字両方）
        container_env_vars+=("HTTP_PROXY=http://squid-proxy:3128")
        container_env_vars+=("HTTPS_PROXY=http://squid-proxy:3128")
        container_env_vars+=("http_proxy=http://squid-proxy:3128")
        container_env_vars+=("https_proxy=http://squid-proxy:3128")
        container_env_vars+=("NO_PROXY=localhost,127.0.0.1,squid-proxy")
        container_env_vars+=("no_proxy=localhost,127.0.0.1,squid-proxy")

        # squid-proxyへの依存関係を追加
        # 注：これは後続の処理で適用される
        log_info "Squidプロキシが起動され、許可されたドメインへのアクセスのみが可能になります。"
    fi

    # コンテナ内環境変数をcompose.ymlのenvironmentセクションに追加
    if [ ${#container_env_vars[@]} -gt 0 ]; then
        # 各環境変数をYAML形式で追加
        for env_var in "${container_env_vars[@]}"; do
            # KEY=VALUEの形式を分解
            local key="${env_var%%=*}"
            local value="${env_var#*=}"

            # yqを使って環境変数を追加
            if ! yq eval ".services.claude-code.environment.$key = \"$value\"" -i "$temp_compose_file" 2>/dev/null; then
                log_error "環境変数の追加に失敗しました: $key=$value"
                rm -f "$temp_compose_file"
                return 1
            fi
        done
    fi

    # --block-outboundが指定されている場合、squid-proxyへの依存関係を追加
    if [ "$block_outbound" = true ]; then
        # depends_onを追加（既存のdepends_onがある場合は追加、ない場合は新規作成）
        if ! yq eval '.services.claude-code.depends_on += ["squid-proxy"]' -i "$temp_compose_file" 2>/dev/null; then
            log_error "squid-proxyへの依存関係の追加に失敗しました"
            rm -f "$temp_compose_file"
            return 1
        fi
    fi

    # デバッグ用に一時ファイルの内容を表示（quiet=falseの場合）
    if [ "$quiet" = false ]; then
        echo "Modified compose file:"
        cat "$temp_compose_file"
    fi

    # バージョン取得とロゴの表示（--no-logoが指定されていなければ）
    if [ "$show_logo" = true ]; then
        # compose.ymlからイメージ名を取得
        local docker_image=""
        if [ -f "$temp_compose_file" ] && [ -n "$service" ]; then
            docker_image=$(yq eval ".services.\"$service\".image" "$temp_compose_file" 2>/dev/null)
            if [ "$docker_image" = "null" ] || [ -z "$docker_image" ]; then
                docker_image="unknown"
            fi
        else
            docker_image="unknown"
        fi

        # コンテナ起動前にスピナーを表示
        echo -e "${INFO_COLOR}Claudeコンテナを起動しています...${NC}"

        # スピナーアニメーション
        local spinners=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
        local spinner_count=${#spinners[@]}

        # バックグラウンドで現在のバージョンと最新バージョンを取得
        get_claude_version "$docker_image" >/tmp/claude_version_$$ &
        local version_pid=$!
        get_latest_claude_version >/tmp/claude_latest_version_$$ &
        local latest_pid=$!

        # スピナーを表示しながら待機
        local i=0
        while kill -0 $version_pid 2>/dev/null || kill -0 $latest_pid 2>/dev/null; do
            local spinner=${spinners[$((i % spinner_count))]}
            echo -ne "\r${FRAME_COLOR}${spinner}${NC} バージョン情報を取得中..."
            sleep 0.1
            ((i++))
        done

        # バージョンを読み込む
        wait $version_pid
        wait $latest_pid
        local claude_version=$(cat /tmp/claude_version_$$ 2>/dev/null)
        local latest_version=$(cat /tmp/claude_latest_version_$$ 2>/dev/null)
        rm -f /tmp/claude_version_$$ /tmp/claude_latest_version_$$

        if [ -z "$claude_version" ]; then
            claude_version="unknown"
        fi
        if [ -z "$latest_version" ]; then
            latest_version="unknown"
        fi

        # スピナー行をクリア
        echo -ne "\r\033[K"

        # ロゴを表示
        print_logo "$claude_credential_path" "$claude_config_path" "$use_bedrock" "" "$temp_compose_file" "$service" "$claude_version" "$latest_version" "${mount_info_display[@]}"
    fi

    # --dangerously-skip-permissionsが使用されているかチェック
    local has_skip_permissions=false
    for arg in "${command_args[@]}"; do
        if [ "$arg" = "--dangerously-skip-permissions" ]; then
            has_skip_permissions=true
            break
        fi
    done

    # 統合されたコンテナランナー関数を利用（一時ファイルを指定）
    # 環境変数とコマンド引数の間に -- を追加
    if [ ${#command_args[@]} -gt 0 ]; then
        run_container "${source_paths[0]}" "$temp_compose_file" "$service" "$remove_orphans" "run" "false" "$show_info" "$show_separator" "$quiet" "$container_user" "$workdir" "" "$docker_log_level" "${env_vars[@]}" -- "${command_args[@]}"
    else
        run_container "${source_paths[0]}" "$temp_compose_file" "$service" "$remove_orphans" "run" "false" "$show_info" "$show_separator" "$quiet" "$container_user" "$workdir" "" "$docker_log_level" "${env_vars[@]}"
    fi
    local exit_code=$?

    # 一時ファイルの削除
    rm -f "$temp_compose_file"

    return $exit_code
}

# ヘルプメッセージも更新
show_ccc_help() {
    # ヘルプ用の簡易ロゴ表示（バージョンは省略）
    print_logo "$HOME/.claude" "$HOME/.claude.json" "false" "" "" "" "N/A" "N/A"
    echo -e "\
${BOLD}使用法:${NC} $(basename "$0") [cccオプション] [Claudeオプション] [-- コマンド引数...]
    $(basename "$0") build [--use-cache]
    $(basename "$0") mcp <MCPサブコマンド> [引数...]
    $(basename "$0") mcp build <MCPサーバー名>...
    $(basename "$0") deploy-claude-md

${BOLD}ccc固有オプション:${NC}
    ${GREEN}-s, --source-path PATH${NC}      ソースコードのパスを指定 (複数指定可能、デフォルト: 現在のディレクトリ)
                                             1つだけの場合は /workspace/ に直接マウント
                                             2つ以上の場合はすべて /workspace/<basename> 形式でマウント
    ${GREEN}--compose-path PATH${NC}         Docker Composeファイルのパスを指定 (デフォルト: $PROJECT_ROOT/compose.yml)
    ${GREEN}-S, --service NAME${NC}          実行するサービス名 (デフォルト: claude-code)
    ${GREEN}--config-dir-path PATH${NC}      Claude Code設定ディレクトリのパスを指定 (デフォルト: $PROJECT_ROOT/.claude)
    ${GREEN}--config-file-path PATH${NC}     Claude Code設定ファイルのパスを指定 (デフォルト: ~/.claude.json)
    ${GREEN}--no-rm-orphans${NC}             オーファンコンテナの削除を無効化する (デフォルトは削除する)
    ${GREEN}--no-logo${NC}                   起動時のロゴ表示を無効化する
    ${GREEN}--info${NC}                      設定情報の表示を有効化する
    ${GREEN}--separator${NC}                 区切り線の表示を有効化する
    ${GREEN}--bedrock${NC}                   AWS BedrockのClaude APIを使用する
    ${GREEN}--bedrock-profile PROFILE${NC}   AWSプロファイルを指定
    ${GREEN}--bedrock-region REGION${NC}     AWSリージョンを指定
    ${GREEN}--bedrock-ca-bundle PATH${NC}    AWS CA証明書バンドルを指定
    ${GREEN}--disable-caching${NC}           プロンプトキャッシュを無効化（Anthropic/Bedrock共通）
    ${GREEN}--log-level LEVEL${NC}           Dockerのログレベルを指定 (debug, info, warn, error, fatal)
    ${GREEN}--user USER${NC}                 コンテナ実行時のユーザーを指定 (例: 1000:1000, root)
    ${GREEN}--workdir PATH${NC}              コンテナ内の作業ディレクトリを指定 (デフォルト: /workspace)
    ${GREEN}--set-env KEY=VALUE${NC}         compose.ymlに環境変数を永続的に設定 (複数指定可能)
    ${GREEN}-v, --verbose${NC}               Docker Composeの詳細な出力を表示する (デフォルトは最小限の出力)
    ${GREEN}-h, --help${NC}                  このヘルプメッセージを表示
    ${GREEN}--claude-help${NC}               Claudeコマンドのヘルプを表示
    ${GREEN}--block-outbound${NC}            コンテナのアウトバウンド通信をブロック（セキュリティ強化）
    ${GREEN}--exclusive-edit-mode${NC}       最初に編集したコードの種類に応じて後続の編集を制限
                                       （プロダクトコードを編集後はテストコードの編集を禁止、
                                        テストコードを編集後はプロダクトコードの編集を禁止）
    ${GREEN}--${NC}                          オプション解析の終了を示す。以降の引数はコマンドとして扱われる

${BOLD}Claudeオプション:${NC}
    cccに定義されていないオプションはすべてClaudeコマンドに直接渡されます。
    
    ${DIMMED}例:${NC}
    ${GREEN}-c, --continue${NC}              前のセッションの続きから開始する
    ${GREEN}-r, --resume [sessionId]${NC}    特定のセッションを再開する
    ${GREEN}--model MODEL${NC}               使用するAnthropicモデルを指定
    ${GREEN}--profile PROFILE${NC}           プロファイルを指定
    ${GREEN}--no-interactive${NC}            非対話モードで実行
    
    その他のClaudeオプションについては、コンテナ内で 'claude --help' を実行してください。

${BOLD}buildサブコマンド:${NC}
    Claudeコンテナイメージをビルドします。
    
    ${DIMMED}使用法:${NC}
    ${GREEN}$(basename "$0") build [オプション]${NC}
    
    ${DIMMED}オプション:${NC}
    ${GREEN}--use-cache${NC}    ビルド時にキャッシュを使用する（デフォルト：キャッシュ無効）

${BOLD}deploy-claude-mdサブコマンド:${NC}
    ~/.claude/CLAUDE_*.md形式のファイルからプロジェクトのCLAUDE.mdを配置します。
    
    ${DIMMED}使用法:${NC}
    ${GREEN}$(basename "$0") deploy-claude-md${NC}
    
    ${DIMMED}動作:${NC}
    1. ~/.claude/ ディレクトリのCLAUDE_*.md形式のファイルを検索
    2. fzfが利用可能な場合は対話的選択、不可能な場合は番号選択
    3. 既存のCLAUDE.mdがある場合は日時付きでバックアップ（CLAUDE.YYYYMMDD_HHMMSS.md）
    4. 選択したファイルをプロジェクトルートにCLAUDE.mdとしてコピー
    
    ${DIMMED}ファイル例:${NC}
    - CLAUDE_spec_driven.md → 仕様駆動開発用設定
    - CLAUDE_code_review.md → コードレビュー用設定
    - CLAUDE_testing.md → テスト用設定

${BOLD}mcpサブコマンド:${NC}
    mcpサブコマンドはbuildを除き、すべてClaude Code本体の機能を利用します。
    利用可能なコマンドについては '$(basename "$0") mcp --help' を参照してください。

${BOLD}mcp buildサブコマンド:${NC}
    MCPサーバー設定ファイルを統合して.mcp.jsonを生成します。
    
    ${DIMMED}使用法:${NC}
    ${GREEN}$(basename "$0") mcp build <MCPサーバー名>...${NC}
    
    ${DIMMED}動作:${NC}
    1. 指定されたMCPサーバー名に対して、[サーバー名].jsonファイルを検索
    2. 検索パス（優先順位順）:
       - $PROJECT_ROOT/.claude/mcp/[サーバー名].json    (プロジェクトディレクトリ)
       - ~/.claude/mcp/[サーバー名].json                 (ユーザーディレクトリ)
    3. 見つかった設定ファイルをすべて統合し、プロジェクトルートに.mcp.jsonを生成
    
    ${DIMMED}設定ファイル形式:${NC}
    各MCPサーバー設定ファイル（例: server1.json）:
    {
        \"server1\": {
            \"command\": \"/path/to/server\",
            \"args\": [],
            \"env\": {}
        }
    }
    
    ${DIMMED}生成される.mcp.json:${NC}
    {
        \"mcpServers\": {
            \"server1\": { ... },
            \"server2\": { ... }
        }
    }

"
    return 0
}

# スクリプトが直接実行された場合のみメイン処理を実行
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    ccc_main "$@"
    exit $?
fi
