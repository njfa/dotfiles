#!/bin/bash

# コンテナランナースクリプトのパスを設定
CR_SCRIPT="${CR_SCRIPT:-$HOME/.dotfiles/bin/container-runner}"

# 必要なコマンドの確認
check_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "エラー: 必要なコマンド '$1' が見つかりません。" >&2
        echo "インストールしてから再試行してください。" >&2
        return 1
    fi
    return 0
}

# 必須コマンドのチェック
check_dependencies() {
    local missing_deps=0

    for cmd in docker yq jq; do
        if ! check_command "$cmd"; then
            missing_deps=$((missing_deps + 1))
        fi
    done

    if [ $missing_deps -gt 0 ]; then
        echo "エラー: 依存関係が満たされていません。必要なパッケージをインストールしてください。" >&2
        exit 1
    fi
}

# 依存関係チェック
check_dependencies

# コンテナランナースクリプトの読み込み
if [[ -f "$CR_SCRIPT" ]]; then
    # スクリプトを読み込む
    . "$CR_SCRIPT"
else
    echo "エラー: コンテナランナースクリプトが見つかりません: $CR_SCRIPT" >&2
    echo "環境変数 CR_SCRIPT を設定するか、デフォルトの場所にスクリプトを配置してください。" >&2
    exit 1
fi

# カラー定義（既存のものに追加）
FRAME_COLOR='\033[1;32m'  # 鮮やかな緑色
DIMMED='\033[2m'          # テキストを暗く表示
INFO_COLOR='\033[1;37m'   # 情報表示用のシアン色
UPDATE_COLOR='\033[1;34m' # 更新表示用の黄色

# パスを人間が読みやすい形式に変換する関数
format_path() {
    local path="$1"
    # $HOMEパスを~に置き換える
    if [[ "$path" == "$HOME"* ]]; then
        echo "~${path#$HOME}"
    else
        echo "$path"
    fi
}

# Claude Codeのバージョンを取得する関数
get_claude_version() {
    local docker_image="$1"

    if [ "$docker_image" != "unknown" ] && docker image inspect "$docker_image" >/dev/null 2>&1; then
        local version=$(docker run --rm "$docker_image" npm list -g @anthropic-ai/claude-code --json 2>/dev/null | jq -r '.dependencies."@anthropic-ai/claude-code".version' 2>/dev/null)
        if [ -z "$version" ] || [ "$version" = "null" ]; then
            echo "unknown"
        else
            echo "$version"
        fi
    else
        echo "unknown"
    fi
}

# 最新のClaude Codeバージョンを取得する関数
get_latest_claude_version() {
    local latest_version=$(npm view @anthropic-ai/claude-code version 2>/dev/null)
    if [ -z "$latest_version" ]; then
        echo "unknown"
    else
        echo "$latest_version"
    fi
}

# 認証情報と設定ファイルのパスを含むロゴを表示する関数
print_logo() {
    local credential_path="$1"
    local config_path="$2"
    local use_bedrock="$3"
    local aws_config_path="$4"
    local compose_path="$5"
    local service="$6"
    local claude_version="$7"
    local latest_version="$8"
    shift 8
    local mount_paths=("$@")

    # 固定幅の枠を作成
    local frame_width=50

    # 横線を作成する関数
    create_horizontal_line() {
        local char="$1"
        local line=""
        for ((i=0; i<frame_width; i++)); do
            line="${line}${char}"
        done
        echo "$line"
    }

    # 上部の枠線
    echo -e "${FRAME_COLOR}╭$(create_horizontal_line "─")╮${NC}"

    # タイトル行
    echo -e "${FRAME_COLOR}│ ✻ ${NC}Containered Claude Code (ccc)$(printf '%*s' $((frame_width - 33)) '') ${FRAME_COLOR}│${NC}"

    # 空行
    echo -e "${FRAME_COLOR}│$(printf '%*s' $((frame_width)) '')│${NC}"

    # バージョン行
    local version_display=""

    # バージョン比較と表示テキストの設定
    if [ "$claude_version" != "unknown" ] && [ "$latest_version" != "unknown" ]; then
        if [ "$claude_version" = "$latest_version" ]; then
            version_display="$claude_version ${GREEN}✓${NC}"
        else
            version_display="$claude_version ${UPDATE_COLOR}(latest: $latest_version)${NC}"
        fi
    else
        version_display="$claude_version"
    fi

    # バージョン表示部分の実際の長さを計算（エスケープシーケンスを除く）
    local version_display_length
    if [ "$claude_version" != "unknown" ] && [ "$latest_version" != "unknown" ]; then
        if [ "$claude_version" = "$latest_version" ]; then
            version_display_length=$((${#claude_version} + 2))  # スペース + ✓
        else
            version_display_length=$((${#claude_version} + 11 + ${#latest_version}))  # " (latest: " + latest_version + ")"
        fi
    else
        version_display_length=${#claude_version}
    fi

    echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Claude Code Version:${NC} ${version_display}$(printf '%*s' $((frame_width - 25 - version_display_length)) '') ${FRAME_COLOR}│${NC}"

    # プロバイダー行
    if [ "$use_bedrock" = true ]; then
        local provider_text="AWS Bedrock"
        echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Provider:${NC} ${UPDATE_COLOR}$provider_text${NC}$(printf '%*s' $((frame_width - 14 - ${#provider_text})) '') ${FRAME_COLOR}│${NC}"
    else
        local provider_text="Anthropic"
        echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Provider:${NC} $provider_text$(printf '%*s' $((frame_width - 14 - ${#provider_text})) '') ${FRAME_COLOR}│${NC}"
    fi

    # 区切り線
    echo -e "${FRAME_COLOR}│${DIMMED}$(create_horizontal_line "─")${NC}${FRAME_COLOR}│${NC}"

    # Anthropicの場合の認証情報
    if [ "$use_bedrock" != true ]; then
        # ファイル名のみを取得
        local cred_basename=$(format_path "$credential_path")
        local conf_basename=$(format_path "$config_path")

        # 認証情報行
        echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Credential:${NC} $cred_basename$(printf '%*s' $((frame_width - 16 - ${#cred_basename})) '') ${FRAME_COLOR}│${NC}"

        # 設定ファイル行
        echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Config:${NC} $conf_basename$(printf '%*s' $((frame_width - 12 - ${#conf_basename})) '') ${FRAME_COLOR}│${NC}"
    else
        # Bedrockの場合のAWS設定情報
        if [ -n "$aws_config_path" ]; then
            local aws_conf_basename=$(format_path "$aws_config_path")
            echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}AWS Config:${NC} $aws_conf_basename$(printf '%*s' $((frame_width - 16 - ${#aws_conf_basename})) '') ${FRAME_COLOR}│${NC}"
        fi

        # AWS認証情報の確認
        local auth_method=""
        if [ -n "$bedrock_profile" ]; then
            auth_method="Profile: $bedrock_profile"
        else
            auth_method="Default Credentials"
        fi
        echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}AWS Auth:${NC} $auth_method$(printf '%*s' $((frame_width - 14 - ${#auth_method})) '') ${FRAME_COLOR}│${NC}"
    fi

    # マウントパスの表示（存在する場合）
    if [ ${#mount_paths[@]} -gt 0 ]; then
        # 区切り線
        echo -e "${FRAME_COLOR}│${DIMMED}$(create_horizontal_line "─")${NC}${FRAME_COLOR}│${NC}"

        # マウントパスのヘッダー
        echo -e "${FRAME_COLOR}│${NC}   ${INFO_COLOR}Mount Paths:${NC}$(printf '%*s' $((frame_width - 16)) '') ${FRAME_COLOR}│${NC}"

        # 各マウントパスを表示
        for i in "${!mount_paths[@]}"; do
            local src_path="${mount_paths[$i]}"
            local formatted_path=$(format_path "$src_path")

            # マウント先のパスを決定
            if [ ${#mount_paths[@]} -eq 1 ]; then
                local target_path="/workspace/"
            else
                local target_path="/workspace/$(basename "$src_path")"
            fi

            # パスが長すぎる場合は省略
            local max_path_length=$((frame_width - 7))
            if [ ${#formatted_path} -gt ${max_path_length} ]; then
                # 省略するために`: -`とする必要があるため、空白は削除しないこと
                formatted_path="...${formatted_path: -$((max_path_length - 3))}"
            fi

            echo -e "${FRAME_COLOR}│${NC}     $formatted_path$(printf '%*s' $((frame_width - 6 - ${#formatted_path})) '') ${FRAME_COLOR}│${NC}"
        done
    fi

    # 下部の枠線
    echo -e "${FRAME_COLOR}╰$(create_horizontal_line "─")╯${NC}"
    echo
}

# MCPサブコマンドの処理関数
process_mcp_subcommand() {
    # 引数をローカル変数として受け取る
    local -a args=("$@")

    # MCPサブコマンド用の引数配列
    local -a mcp_args=()
    local processing_json_file=false
    local json_file_processed=false

    # 引数のインデックス
    local i=0

    while [ $i -lt ${#args[@]} ]; do
        local arg="${args[$i]}"

        if [ "$processing_json_file" = true ]; then
            # add-json-fileの次の引数（サービス名）を処理
            mcp_args+=("$arg")
            processing_json_file=false
            json_file_processed=true
            ((i++))

            if [ $i -ge ${#args[@]} ]; then
                log_error "add-json-fileの後にJSONファイル名が指定されていません"
                return 1
            fi

            # JSONファイル名を処理
            local json_file="${args[$i]}"
            local service_name="${mcp_args[-1]}" # 直前に追加したサービス名を取得

            # JSONファイルの存在確認
            if [ ! -f "$json_file" ]; then
                log_error "JSONファイルが見つかりません: $json_file"
                return 1
            fi

            # jqでJSONファイルを読み込み、1行のJSON文字列に変換
            local json_content=$(jq -rc . "$json_file" 2>/dev/null)
            if [ $? -ne 0 ] || [ -z "$json_content" ]; then
                log_error "JSONファイルの読み込みまたは解析に失敗しました: $json_file"
                return 1
            fi

            # MCP設定ファイルのパス（プロジェクトルートのmcp-config.ymlを優先）
            local mcp_env_req_file=""
            if [ -f "./mcp-config.yml" ]; then
                mcp_env_req_file="./mcp-config.yml"
            elif [ -f "$HOME/.dotfiles/mcp-config.yml" ]; then
                mcp_env_req_file="$HOME/.dotfiles/mcp-config.yml"
            elif [ -f "$HOME/.dotfiles/etc/mcp-env-requirements.yml" ]; then
                # 後方互換性のため古いパスもチェック
                mcp_env_req_file="$HOME/.dotfiles/etc/mcp-env-requirements.yml"
            fi

            # YAMLファイルが存在する場合のみ検証を実行
            if [ -f "$mcp_env_req_file" ]; then
                # argsに設定されたMCPを確認
                local args_array=$(echo "$json_content" | jq -r '.args[]?' 2>/dev/null)

                if [ -n "$args_array" ]; then
                    # 各argsに対してYAMLファイルから必須環境変数を取得
                    while IFS= read -r mcp_arg; do
                        # YAMLファイルから該当MCPの必須環境変数リストを取得
                        local required_envs=$(yq eval ".\"$mcp_arg\" // []" "$mcp_env_req_file" 2>/dev/null)

                        # 必須環境変数が定義されている場合
                        if [ -n "$required_envs" ] && [ "$required_envs" != "[]" ]; then
                            # 各必須環境変数をチェック
                            while IFS= read -r env_name; do
                                # "- "プレフィックスを削除
                                env_name=$(echo "$env_name" | sed 's/^- //')

                                # 既存の環境変数値を取得
                                local env_value=$(echo "$json_content" | jq -r ".env.${env_name} // empty" 2>/dev/null)

                                # 環境変数が未設定の場合、入力を求める
                                if [ -z "$env_value" ]; then
                                    echo -n "${env_name}を入力してください: "
                                    read -r env_value < /dev/tty
                                    if [ -z "$env_value" ]; then
                                        log_error "${env_name}は必須です"
                                        return 1
                                    fi
                                    # JSONコンテンツに環境変数を追加
                                    json_content=$(echo "$json_content" | jq --arg key "$env_name" --arg val "$env_value" '.env[$key] = $val')
                                fi
                            done <<< "$required_envs"
                            break # 最初にマッチしたMCPの設定のみを処理
                        fi
                    done <<< "$args_array"
                fi
            fi

            # 処理したJSONをmcp_argsに追加
            mcp_args+=("$json_content")

        elif [ "$arg" = "add-json-file" ] && [ "$json_file_processed" = false ]; then
            # add-json-fileコマンドを検出
            mcp_args+=("add-json")
            processing_json_file=true
        else
            # その他の引数はそのまま追加
            mcp_args+=("$arg")
        fi

        ((i++))
    done

    # command_argsに設定（グローバル変数を想定）
    command_args=("claude" "mcp" "${mcp_args[@]}")

    return 0
}

# Claudeイメージの更新確認関数
check_claude_update() {
    log_info "Claudeイメージの更新を確認中..."

    # npmでインストールされたclaude-codeの最新バージョンを取得
    local latest_version=$(npm view @anthropic-ai/claude-code version 2>/dev/null)
    if [ -z "$latest_version" ]; then
        log_error "最新バージョンの取得に失敗しました"
        return 1
    fi

    # コンテナ内のclaude-codeバージョンを取得
    local container_version=""
    container_version=$(docker run --rm my-claude-code:latest npm list -g @anthropic-ai/claude-code --json 2>/dev/null | jq -r '.dependencies."@anthropic-ai/claude-code".version' 2>/dev/null)

    if [ -z "$container_version" ] || [ "$container_version" = "null" ]; then
        log_warning "コンテナ内のバージョン情報を取得できませんでした"
        echo -e "${UPDATE_COLOR}利用可能なアップデート:${NC} 不明 → $latest_version"
        return 0
    fi

    # バージョン比較
    if [ "$container_version" != "$latest_version" ]; then
        echo -e "${UPDATE_COLOR}利用可能なアップデート:${NC} $container_version → $latest_version"
        return 0
    else
        echo -e "${GREEN}Claudeは最新バージョンです:${NC} $container_version"
        return 0
    fi
}

# Claudeイメージの更新関数
update_claude_image() {
    local use_cache="$1"
    log_info "Claudeイメージを更新中..."

    local build_args=()

    # use_cacheフラグをチェック
    if [ "$use_cache" = "use_cache" ]; then
        log_info "キャッシュを使用してビルドします"
    else
        log_info "キャッシュを無効化してビルドします"
        build_args+=("--no-cache")
    fi

    # イメージの再ビルド
    if ! docker compose -f "$HOME/.dotfiles/compose.yml" build "${build_args[@]}" containered-claude; then
        log_error "イメージの更新に失敗しました"
        return 1
    fi

    log_success "Claudeイメージが正常に更新されました"
    return 0
}

# メイン関数
ccc_main() {
    # デフォルト値の設定
    local source_paths=()
    local compose_path="$HOME/.dotfiles/compose.yml"
    local service="containered-claude"
    local remove_orphans=true # デフォルトでオーファンコンテナを削除する
    local claude_credential_path="$HOME/.claude"
    local claude_config_path="$HOME/.claude.json"
    local command_args=("claude") # デフォルトのコマンド
    local show_logo=true # デフォルトでロゴを表示
    local show_info=false # デフォルトで設定情報を表示
    local show_separator=false # デフォルトでセパレータを表示
    local quiet=true # デフォルトは静かモード
    local workdir=""          # 作業ディレクトリ (--workdir)
    local source_path_specified=false # ソースパスが指定されたかどうかのフラグ
    local do_update=false # 更新実行フラグ
    local use_cache=false # ビルド時のキャッシュ使用フラグ
    local use_bedrock=false # Bedrock使用フラグ
    local bedrock_region="" # Bedrockリージョン
    local bedrock_profile="" # AWS プロファイル
    local bedrock_config_file="" # AWS設定ファイルパス
    local bedrock_ca_bundle="" # AWS CA証明書バンドルパス
    local bedrock_disable_caching=false # プロンプトキャッシュ無効化フラグ
    local model="" # Anthropicモデル
    local fast_model="" # Anthropicの高速な小型モデル
    local docker_log_level="" # Dockerログレベル
    local mcp_subcommand_args=() # MCPサブコマンド用引数
    local mcp_services=() # 起動するMCPサービスのリスト
    local stop_mcp_services=false # MCPサービス停止フラグ
    local container_user="" # コンテナ実行ユーザー

    # オプションと引数の解析
    while [[ $# -gt 0 ]]; do
        case $1 in
            -s | --source-path)
                source_paths+=("$2")
                source_path_specified=true
                shift 2
                ;;
            -c)
                # Claudeの--continueオプションとして扱う
                command_args+=("--continue")
                shift
                ;;
            --continue)
                # Claudeの--continueオプション
                command_args+=("--continue")
                shift
                ;;
            --compose-path)
                compose_path="$2"
                shift 2
                ;;
            -S | --service)
                service="$2"
                shift 2
                ;;
            -r)
                # Claudeの--resumeオプションとして扱う
                if [ $# -gt 1 ] && [[ "$2" != -* ]]; then
                    # セッションIDが指定されている場合
                    command_args+=("--resume" "$2")
                    shift 2
                else
                    # セッションIDが省略されている場合
                    command_args+=("--resume")
                    shift
                fi
                ;;
            --resume)
                # Claudeの--resumeオプション
                if [ $# -gt 1 ] && [[ "$2" != -* ]]; then
                    # セッションIDが指定されている場合
                    command_args+=("--resume" "$2")
                    shift 2
                else
                    # セッションIDが省略されている場合
                    command_args+=("--resume")
                    shift
                fi
                ;;
            --credential-path)
                claude_credential_path="$2"
                shift 2
                ;;
            --config-path)
                claude_config_path="$2"
                shift 2
                ;;
            --bedrock-profile)
                bedrock_profile="$2"
                shift 2
                ;;
            --bedrock-region)
                bedrock_region="$2"
                shift 2
                ;;
            --bedrock-config-file)
                bedrock_config_file="$2"
                shift 2
                ;;
            --bedrock-ca-bundle)
                bedrock_ca_bundle="$2"
                shift 2
                ;;
            --bedrock-disable-caching)
                bedrock_disable_caching=true
                shift
                ;;
            --model)
                model="$2"
                shift 2
                ;;
            --fast-model)
                fast_model="$2"
                shift 2
                ;;
            --workdir)
                workdir="$2"
                shift 2
                ;;
            --no-rm-orphans)
                remove_orphans=false
                shift
                ;;
            --no-logo)
                show_logo=false
                shift
                ;;
            --info)
                show_info=true
                shift
                ;;
            --separator)
                show_separator=true
                shift
                ;;
            --update)
                do_update=true
                shift
                ;;
            --use-cache)
                use_cache=true
                shift
                ;;
            --bedrock)
                use_bedrock=true
                # --bedrockオプションはccc専用でClaudeコマンドには渡さない
                shift
                ;;
            --log-level)
                docker_log_level="$2"
                shift 2
                ;;
            --mcp)
                mcp_services+=("$2")
                shift 2
                ;;
            --stop-mcp)
                stop_mcp_services=true
                shift
                ;;
            --user)
                container_user="$2"
                shift 2
                ;;
            -v | --verbose)
                quiet=false
                shift
                ;;
            -h | --help)
                show_ccc_help
                return 0
                ;;
            mcp)
                # mcpサブコマンドが指定された場合
                shift
                # 残りの引数を関数に渡して処理を任せる
                if [ $# -gt 0 ]; then
                    mcp_subcommand_args=("$@")
                fi
                break
                ;;
            --)
                shift
                # "--" 以降の引数があればそれをコマンドとして使用
                if [ $# -gt 0 ]; then
                    command_args=("$@")
                fi
                break
                ;;
            *)
                log_error "不明なオプション: $1"
                show_ccc_help
                return 1
                ;;
        esac
    done

    # 更新が要求された場合
    if [ "$do_update" = true ]; then
        if [ "$use_cache" = true ]; then
            update_claude_image "use_cache"
        else
            update_claude_image
        fi
        return $?
    fi

    # source_pathsが空の場合は現在のディレクトリを使用
    if [ ${#source_paths[@]} -eq 0 ]; then
        source_paths=($(pwd))
    fi

    # 認証情報ディレクトリの存在確認と作成
    if [ ! -d "$claude_credential_path" ]; then
        log_info "認証情報ディレクトリ '$claude_credential_path' が見つかりません。作成します。"
        mkdir -p "$claude_credential_path" || {
            log_error "認証情報ディレクトリの作成に失敗しました: $claude_credential_path"
                    return 1
                }
            log_success "認証情報ディレクトリを作成しました: $claude_credential_path"
    fi

    # 設定ファイルの存在確認と作成
    if [ ! -f "$claude_config_path" ]; then
        log_info "設定ファイル '$claude_config_path' が見つかりません。作成します。"
        echo -n "Claude設定ファイルの内容を入力してください (Enterで空のJSONを使用): "
        read -r config_content < /dev/tty

        # 入力がない場合は空のJSONオブジェクトを使用
        if [ -z "$config_content" ]; then
            config_content="{}"
        fi

        # JSONの妥当性を検証
        if ! echo "$config_content" | jq . >/dev/null 2>&1; then
            log_error "入力されたJSONが無効です。空のJSONオブジェクトを使用します。"
            config_content="{}"
        fi

        # ファイルに書き込み
        echo "$config_content" > "$claude_config_path" || {
            log_error "設定ファイルの作成に失敗しました: $claude_config_path"
                    return 1
                }
            log_success "設定ファイルを作成しました: $claude_config_path"
    fi

    # 起動時に自動で更新確認（1日以上経過している場合）
    local update_check_file="$HOME/.claude_update_check"
    local last_check=0
    local current_time=$(date +%s)
    local one_day=$((24 * 60 * 60)) # 1日の秒数

    # 最終確認日時を読み込む
    if [ -f "$update_check_file" ]; then
        last_check=$(cat "$update_check_file" 2>/dev/null)
        # 数字でない場合はデフォルト値を使用
        if ! [[ "$last_check" =~ ^[0-9]+$ ]]; then
            last_check=0
    # Bedrock使用時のAWS設定ディレクトリの確認と設定
    if [ "$use_bedrock" = true ]; then
        # bedrock_config_fileが指定されていない場合はデフォルトを設定
        if [ -z "$bedrock_config_file" ]; then
            bedrock_config_file="$HOME/.aws"
        fi

        # AWS設定ディレクトリが存在しない場合はaws configureを実行
        if [ ! -d "$bedrock_config_file" ]; then
            log_info "AWS設定ディレクトリ '$bedrock_config_file' が見つかりません。AWS設定を行います。"

            # プロファイルオプションの設定
            local aws_configure_cmd="aws configure"
            if [ -n "$bedrock_profile" ]; then
                aws_configure_cmd="aws configure --profile $bedrock_profile"
                log_info "プロファイル '$bedrock_profile' で設定を行います。"
            fi

            # aws configureを実行
            if ! $aws_configure_cmd; then
                log_error "AWS設定に失敗しました。"
                return 1
            fi

            # ディレクトリが作成されたことを確認
            if [ ! -d "$bedrock_config_file" ]; then
                log_error "AWS設定ディレクトリが作成されませんでした: $bedrock_config_file"
                return 1
            fi

            log_success "AWS設定が完了しました。"
        fi
    fi


    # 環境変数を準備
    local env_vars=(
    "CLAUDE_CREDENTIAL_PATH=$claude_credential_path"
    "CLAUDE_CONFIG_PATH=$claude_config_path"
)

    # AWS設定パスが指定されている場合
    if [ -n "$aws_config_path" ]; then
        env_vars+=("AWS_CONFIG_PATH=$aws_config_path")
    fi

    # Bedrock使用時の環境変数設定
    # 優先順位: 環境変数 > AWS config/credential
    # AWS SDKは環境変数を優先的に使用するため、環境変数が設定されている場合は
    # AWS config/credentialファイルの内容より環境変数の値が使用される
    if [ "$use_bedrock" = true ]; then
        # CLAUDE_CODE_USE_BEDROCKを設定
        env_vars+=("CLAUDE_CODE_USE_BEDROCK=1")

        # プロファイルが指定されている場合
        if [ -n "$bedrock_profile" ]; then
            env_vars+=("AWS_PROFILE=$bedrock_profile")
        fi

        # リージョンが指定されている場合
        if [ -n "$bedrock_region" ]; then
            env_vars+=("AWS_REGION=$bedrock_region")
        fi

        # CA証明書バンドルが指定されている場合
        if [ -n "$bedrock_ca_bundle" ]; then
            env_vars+=("AWS_CA_BUNDLE=$bedrock_ca_bundle")
        fi

        # プロンプトキャッシュ無効化フラグ
        if [ "$bedrock_disable_caching" = true ]; then
            env_vars+=("DISABLE_PROMPT_CACHING=1")
        fi
    fi

    # モデル指定がある場合
    if [ -n "$model" ]; then
        env_vars+=("ANTHROPIC_MODEL=$model")
    fi

    # 高速モデル指定がある場合
    if [ -n "$fast_model" ]; then
        env_vars+=("ANTHROPIC_SMALL_FAST_MODEL=$fast_model")
    fi

    # タイムゾーン情報を取得して設定
    local tz
    if command -v timedatectl >/dev/null 2>&1; then
        tz=$(timedatectl | grep "Time zone" | awk '{print $3}')
        if [ -n "$tz" ]; then
            env_vars+=("TZ=$tz")
        fi
    fi

    # SOURCE_PATH環境変数は-sオプションが指定されていない場合のみ設定
    if [ "$source_path_specified" = false ]; then
        env_vars+=("SOURCE_PATH=${source_paths[0]}")
    fi

    # 一時ファイルの作成
    local temp_compose_file=$(mktemp)

    # composeファイルのコピーと存在確認
    if [ ! -f "$compose_path" ]; then
        log_error "指定されたComposeファイル '$compose_path' が見つかりません。"
        return 1
    fi

    cp "$compose_path" "$temp_compose_file" || {
        log_error "Composeファイルのコピーに失敗しました: $compose_path"
            return 1
        }

    # ユーザーが-s/--source-pathを指定した場合、デフォルトのマウント設定を削除
    if [ "$source_path_specified" = true ]; then
        if ! yq eval 'del(.services.containered-claude.volumes[] | select(.target == "/workspace/"))' -i "$temp_compose_file" 2>/dev/null; then
            log_error "yqコマンドの実行に失敗しました。yqが正しくインストールされているか確認してください。"
            rm -f "$temp_compose_file"
            return 1
        fi
    fi

    # ソースパスが指定されている場合、マウント設定を追加
    if [ "$source_path_specified" = true ]; then
        # 各ソースパスの存在確認
        for src_path in "${source_paths[@]}"; do
            if [ ! -d "$src_path" ]; then
                log_error "指定されたソースパス '$src_path' が存在しないか、ディレクトリではありません。"
                rm -f "$temp_compose_file"
                return 1
            fi
        done

        # 既に使用されているマウント先ディレクトリ名を追跡
        declare -A target_dirs

        # ソースパスが1つの場合は直接 /workspace/ にマウント
        if [ ${#source_paths[@]} -eq 1 ]; then
            if ! yq eval ".services.containered-claude.volumes += [{\"type\": \"bind\", \"source\": \"${source_paths[0]}\", \"target\": \"/workspace/\"}]" -i "$temp_compose_file" 2>/dev/null; then
                log_error "マウント設定の追加に失敗しました: ${source_paths[0]}"
                rm -f "$temp_compose_file"
                return 1
            fi
        else
            # ソースパスが複数の場合は、すべてbasename形式でマウント
            for ((i=0; i<${#source_paths[@]}; i++)); do
                local src_path="${source_paths[$i]}"
                local dir_name=$(basename "$src_path")
                local target_name="$dir_name"
                local counter=1

                # ディレクトリ名が重複する場合、連番を付与
                while [[ ${target_dirs[$target_name]} ]]; do
                    target_name="${dir_name}-${counter}"
                    ((counter++))
                done

                # 使用したディレクトリ名を記録
                target_dirs[$target_name]=1
                local target_path="/workspace/$target_name"

                # yqを使って新しいマウントポイントを追加
                if ! yq eval ".services.containered-claude.volumes += [{\"type\": \"bind\", \"source\": \"$src_path\", \"target\": \"$target_path\"}]" -i "$temp_compose_file" 2>/dev/null; then
                    log_error "マウント設定の追加に失敗しました: $src_path -> $target_path"
                    rm -f "$temp_compose_file"
                    return 1
                fi
            done
        fi
    fi

    # Bedrock使用時のAWS設定ディレクトリのマウント設定
    if [ "$use_bedrock" = true ]; then
        # この時点でbedrock_config_fileは存在が保証されている（前の処理で確認・作成済み）
        # AWS設定ディレクトリをマウント
        if ! yq eval ".services.containered-claude.volumes += [{\"type\": \"bind\", \"source\": \"$bedrock_config_file\", \"target\": \"/home/node/.aws\"}]" -i "$temp_compose_file" 2>/dev/null; then
            log_error "AWS設定ディレクトリのマウント設定の追加に失敗しました: $bedrock_config_file"
            rm -f "$temp_compose_file"
            return 1
        fi

        log_info "AWS設定ディレクトリをマウント: $bedrock_config_file -> /home/node/.aws"
    fi

    # デバッグ用に一時ファイルの内容を表示（quiet=falseの場合）
    if [ "$quiet" = false ]; then
        echo "Modified compose file:"
        cat "$temp_compose_file"
    fi

    # Bedrock引数の設定は削除（環境変数で制御するため）

    # MCPサービスの起動処理
    local mcp_containers=()
    local container_prerequisites=()  # コンテナ内で実行する前提条件を保存

    if [ ${#mcp_services[@]} -gt 0 ]; then
        log_info "MCPサービスを起動中..."

        # MCP設定ファイルのパス（プロジェクトルートのmcp-config.ymlを優先）
        local mcp_env_req_file=""
        if [ -f "./mcp-config.yml" ]; then
            mcp_env_req_file="./mcp-config.yml"
        elif [ -f "$HOME/.dotfiles/mcp-config.yml" ]; then
            mcp_env_req_file="$HOME/.dotfiles/mcp-config.yml"
        elif [ -f "$HOME/.dotfiles/etc/mcp-env-requirements.yml" ]; then
            # 後方互換性のため古いパスもチェック
            mcp_env_req_file="$HOME/.dotfiles/etc/mcp-env-requirements.yml"
        fi

        # 各MCPサービスの処理
        for mcp_service in "${mcp_services[@]}"; do
            local service_in_compose=false
            local service_started=false

            # 1. compose.ymlにサービスが定義されているか確認
            if yq -e ".services.\"$mcp_service\"" "$temp_compose_file" >/dev/null 2>&1; then
                service_in_compose=true
            fi

            # 2. mcp-env-requirements.ymlの前提条件をチェックして実行（compose.ymlの定義有無に関係なく）
            if [ -f "$mcp_env_req_file" ]; then
                # 前提条件が定義されているか確認
                local prerequisites=$(yq eval ".\"$mcp_service\".prerequisites // []" "$mcp_env_req_file" 2>/dev/null)

                if [ -n "$prerequisites" ] && [ "$prerequisites" != "[]" ]; then
                    log_info "MCPサービス '$mcp_service' の前提条件を確認中..."

                    # 各前提条件を処理
                    local prereq_count=$(echo "$prerequisites" | yq eval '. | length' -)
                    for ((i=0; i<$prereq_count; i++)); do
                        local command=$(echo "$prerequisites" | yq eval ".[$i].command" -)
                        local description=$(echo "$prerequisites" | yq eval ".[$i].description // \"\"" -)
                        local check=$(echo "$prerequisites" | yq eval ".[$i].check // \"\"" -)
                        local is_host=$(echo "$prerequisites" | yq eval ".[$i].host // false" -)

                        # チェックコマンドが定義されている場合、まず確認
                        local need_execute=true
                        if [ -n "$check" ] && [ "$check" != "null" ]; then
                            if eval "$check" >/dev/null 2>&1; then
                                need_execute=false
                                log_info "✓ $description (既に設定済み)"
                            fi
                        fi

                        # 前提条件を実行
                        if [ "$need_execute" = true ]; then
                            if [ -n "$description" ] && [ "$description" != "null" ]; then
                                log_info "実行: $description"
                            fi

                            if [ "$is_host" = "true" ]; then
                                # ホスト側で実行（バックグラウンド実行を考慮）
                                local background=$(echo "$prerequisites" | yq eval ".[$i].background // false" -)

                                if [ "$background" = "true" ]; then
                                    # バックグラウンドで実行
                                    log_info "バックグラウンドで実行: $command"
                                    if eval "$command &"; then
                                        log_success "前提条件をバックグラウンドで実行しました: $command"
                                    else
                                        log_warning "前提条件のバックグラウンド実行に失敗しました: $command"
                                    fi
                                else
                                    # フォアグラウンドで実行
                                    if eval "$command"; then
                                        log_success "前提条件を実行しました: $command"
                                    else
                                        log_warning "前提条件の実行に失敗しました: $command"
                                    fi
                                fi
                            else
                                # コンテナ内で実行するために保存（バックグラウンドフラグも含める）
                                local background=$(echo "$prerequisites" | yq eval ".[$i].background // false" -)
                                container_prerequisites+=("{\"service\":\"$mcp_service\",\"command\":\"$command\",\"description\":\"$description\",\"background\":$background}")
                                log_info "コンテナ起動後に実行予定: $command"
                            fi
                        fi
                    done
                fi
            fi

            # 3. compose.ymlに定義がある場合はMCPサービスを起動
            if [ "$service_in_compose" = true ]; then
                log_info "MCPサービス '$mcp_service' を起動しています..."
                if docker compose -f "$temp_compose_file" up -d "$mcp_service" >/dev/null 2>&1; then
                    mcp_containers+=("$mcp_service")
                    service_started=true
                    log_success "MCPサービス '$mcp_service' が起動しました"

                    # コンテナ内で実行する前提条件があれば実行
                    for prereq_json in "${container_prerequisites[@]}"; do
                        local prereq_service=$(echo "$prereq_json" | jq -r '.service')
                        if [ "$prereq_service" = "$mcp_service" ]; then
                            local prereq_command=$(echo "$prereq_json" | jq -r '.command')
                            local prereq_description=$(echo "$prereq_json" | jq -r '.description')

                            local prereq_background=$(echo "$prereq_json" | jq -r '.background')

                            log_info "コンテナ内で前提条件を実行: $prereq_description"

                            if [ "$prereq_background" = "true" ]; then
                                # バックグラウンドで実行
                                if docker exec -d "$mcp_service" sh -c "$prereq_command"; then
                                    log_success "コンテナ内で前提条件をバックグラウンドで実行しました: $prereq_command"
                                else
                                    log_warning "コンテナ内での前提条件のバックグラウンド実行に失敗しました: $prereq_command"
                                fi
                            else
                                # フォアグラウンドで実行
                                if docker exec "$mcp_service" sh -c "$prereq_command"; then
                                    log_success "コンテナ内で前提条件を実行しました: $prereq_command"
                                else
                                    log_warning "コンテナ内での前提条件の実行に失敗しました: $prereq_command"
                                fi
                            fi
                        fi
                    done
                else
                    log_error "MCPサービス '$mcp_service' の起動に失敗しました"
                fi
            fi

            # 4. compose.ymlに定義がなく、mcp-env-requirements.ymlにも定義がない場合は警告
            if [ "$service_in_compose" = false ] && [ "$service_started" = false ]; then
                # mcp-env-requirements.ymlに何らかの定義があるかチェック
                local has_mcp_definition=false
                if [ -f "$mcp_env_req_file" ]; then
                    if yq -e ".\"$mcp_service\"" "$mcp_env_req_file" >/dev/null 2>&1; then
                        has_mcp_definition=true
                    fi
                fi

                if [ "$has_mcp_definition" = false ]; then
                    log_warning "MCPサービス '$mcp_service' はcompose.ymlおよびmcp-env-requirements.ymlに定義されていません"
                fi
            fi
        done
    fi

    # バージョン取得とロゴの表示（--no-logoが指定されていなければ）
    if [ "$show_logo" = true ]; then
        # compose.ymlからイメージ名を取得
        local docker_image=""
        if [ -f "$temp_compose_file" ] && [ -n "$service" ]; then
            docker_image=$(yq eval ".services.\"$service\".image" "$temp_compose_file" 2>/dev/null)
            if [ "$docker_image" = "null" ] || [ -z "$docker_image" ]; then
                docker_image="unknown"
            fi
        else
            docker_image="unknown"
        fi

        # コンテナ起動前にスピナーを表示
        echo -e "${INFO_COLOR}Claudeコンテナを起動しています...${NC}"

        # スピナーアニメーション
        local spinners=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
        local spinner_count=${#spinners[@]}

        # バックグラウンドで現在のバージョンと最新バージョンを取得
        get_claude_version "$docker_image" > /tmp/claude_version_$$ &
        local version_pid=$!
        get_latest_claude_version > /tmp/claude_latest_version_$$ &
        local latest_pid=$!

        # スピナーを表示しながら待機
        local i=0
        while kill -0 $version_pid 2>/dev/null || kill -0 $latest_pid 2>/dev/null; do
            local spinner=${spinners[$((i % spinner_count))]}
            echo -ne "\r${FRAME_COLOR}${spinner}${NC} バージョン情報を取得中..."
            sleep 0.1
            ((i++))
        done

        # バージョンを読み込む
        wait $version_pid
        wait $latest_pid
        local claude_version=$(cat /tmp/claude_version_$$ 2>/dev/null)
        local latest_version=$(cat /tmp/claude_latest_version_$$ 2>/dev/null)
        rm -f /tmp/claude_version_$$ /tmp/claude_latest_version_$$

        if [ -z "$claude_version" ]; then
            claude_version="unknown"
        fi
        if [ -z "$latest_version" ]; then
            latest_version="unknown"
        fi

        # スピナー行をクリア
        echo -ne "\r\033[K"

        # ロゴを表示
        print_logo "$claude_credential_path" "$claude_config_path" "$use_bedrock" "$bedrock_config_file" "$temp_compose_file" "$service" "$claude_version" "$latest_version" "${source_paths[@]}"
    fi

    if [ ${#mcp_subcommand_args[@]} -gt 0 ]; then
        process_mcp_subcommand "${mcp_subcommand_args[@]}"
        if [ $? -ne 0 ]; then
            return 1
        fi
    fi

    # 統合されたコンテナランナー関数を利用（一時ファイルを指定）
    # 環境変数とコマンド引数の間に -- を追加
    if [ ${#command_args[@]} -gt 0 ]; then
        run_container "${source_paths[0]}" "$temp_compose_file" "$service" "$remove_orphans" "run" "false" "$show_info" "$show_separator" "$quiet" "$container_user" "$workdir" "" "$docker_log_level" "${env_vars[@]}" -- "${command_args[@]}"
    else
        run_container "${source_paths[0]}" "$temp_compose_file" "$service" "$remove_orphans" "run" "false" "$show_info" "$show_separator" "$quiet" "$container_user" "$workdir" "" "$docker_log_level" "${env_vars[@]}"
    fi
    local exit_code=$?

    # 一時ファイルの削除
    rm -f "$temp_compose_file"

    # MCPサービスの停止処理（--stop-mcpが指定された場合のみ）
    if [ "$stop_mcp_services" = true ] && [ ${#mcp_containers[@]} -gt 0 ]; then
        log_info "MCPサービスを停止中..."
        for mcp_service in "${mcp_containers[@]}"; do
            if docker compose -f "$compose_path" stop "$mcp_service" >/dev/null 2>&1; then
                log_success "MCPサービス '$mcp_service' を停止しました"
            else
                log_warning "MCPサービス '$mcp_service' の停止に失敗しました"
            fi
        done
    fi

    return $exit_code
}

# ヘルプメッセージも更新
show_ccc_help() {
    # ヘルプ用の簡易ロゴ表示（バージョンは省略）
    print_logo "$HOME/.claude" "$HOME/.claude.json" "false" "" "" "" "N/A" "N/A"
    echo -e "\
${BOLD}使用法:${NC} $(basename "$0") [オプション] [-- コマンド引数...]
    $(basename "$0") mcp <MCPサブコマンド> [引数...]

${BOLD}オプション:${NC}
    ${GREEN}-s, --source-path PATH${NC}      ソースコードのパスを指定 (複数指定可能、デフォルト: 現在のディレクトリ)
                                             1つだけの場合は /workspace/ に直接マウント
                                             2つ以上の場合はすべて /workspace/<basename> 形式でマウント
    ${GREEN}--compose-path PATH${NC}         Docker Composeファイルのパスを指定 (デフォルト: ~/.dotfiles/compose.yml)
    ${GREEN}-S, --service NAME${NC}          実行するサービス名 (デフォルト: containered-claude)
    ${GREEN}-c, --continue${NC}              前のセッションの続きから開始する (Claudeに直接渡される)
    ${GREEN}-r, --resume [sessionId]${NC}    特定のセッションを再開する (Claudeに直接渡される)
    ${GREEN}--credential-path PATH${NC}      Claude認証情報ディレクトリのパスを指定 (デフォルト: ~/.claude)
    ${GREEN}--config-path PATH${NC}          Claude設定ファイルのパスを指定 (デフォルト: ~/.claude.json)
    ${GREEN}--no-rm-orphans${NC}             オーファンコンテナの削除を無効化する (デフォルトは削除する)
    ${GREEN}--no-logo${NC}                   起動時のロゴ表示を無効化する
    ${GREEN}--info${NC}                      設定情報の表示を有効化する
    ${GREEN}--separator${NC}                 区切り線の表示を有効化する
    ${GREEN}--check-update${NC}              Claudeイメージの更新を確認する
    ${GREEN}--update${NC}                    利用可能な場合、Claudeイメージを更新する (デフォルトはキャッシュ無効)
    ${GREEN}--use-cache${NC}                 --updateと組み合わせて使用し、ビルド時にキャッシュを有効化する
                                             環境が1つのみ定義されている場合は自動的に選択される
    ${GREEN}--bedrock${NC}                   AWS BedrockのClaude APIを使用する
    ${GREEN}--bedrock-profile PROFILE${NC}   AWSプロファイルを指定
    ${GREEN}--bedrock-region REGION${NC}     AWSリージョンを指定
    ${GREEN}--bedrock-config-file PATH${NC}  AWS設定ディレクトリを指定 (デフォルト: ~/.aws)
    ${GREEN}--bedrock-ca-bundle PATH${NC}    AWS CA証明書バンドルを指定
    ${GREEN}--bedrock-disable-caching${NC}   プロンプトキャッシュを無効化
    ${GREEN}--model MODEL${NC}               Anthropicモデルを指定
    ${GREEN}--fast-model MODEL${NC}          Anthropicの高速な小型モデルを指定
    ${GREEN}--log-level LEVEL${NC}           Dockerのログレベルを指定 (debug, info, warn, error, fatal)
    ${GREEN}--mcp SERVICE${NC}               起動するMCPサービスを指定 (複数指定可能)
    ${GREEN}--stop-mcp${NC}                  終了時にMCPサービスも停止する (デフォルトは停止しない)
    ${GREEN}--user USER${NC}                 コンテナ実行時のユーザーを指定 (例: 1000:1000, root)
    ${GREEN}-v, --verbose${NC}               Docker Composeの詳細な出力を表示する (デフォルトは最小限の出力)
    ${GREEN}-h, --help${NC}                  このヘルプメッセージを表示
    ${GREEN}--${NC}                          オプション解析の終了を示す。以降の引数はコマンドとして扱われる

${BOLD}MCPサブコマンド:${NC}
    ${GREEN}mcp list${NC}                    利用可能なMCPサーバーの一覧を表示
    ${GREEN}mcp add <name>${NC}              MCPサーバーを追加
    ${GREEN}mcp add-json <name> <json>${NC}  JSON形式でMCPサーバーを追加
    ${GREEN}mcp add-json-file <name> <file>${NC}  JSONファイルからMCPサーバーを追加 (ccc固有機能)
    ${GREEN}mcp remove <name>${NC}           MCPサーバーを削除
    ${GREEN}mcp enable <name>${NC}           MCPサーバーを有効化
    ${GREEN}mcp disable <name>${NC}          MCPサーバーを無効化

${BOLD}mcp add-json-fileの詳細 (ccc固有機能):${NC}
    JSONファイルからMCPサーバー設定を読み込んで追加する機能である。

${DIMMED}使用例:${NC}
    $(basename "$0") mcp add-json-file gitlab ./mcp.gitlab.json

${DIMMED}JSONファイル形式:${NC}
    {
        \"command\": \"npx\",
        \"args\": [\"@modelcontextprotocol/server-gitlab\"],
        \"env\": {
            \"GITLAB_PERSONAL_ACCESS_TOKEN\": \"your-token\",
            \"GITLAB_API_URL\": \"https://gitlab.com/api/v4\"
        }
    }

${DIMMED}MCP環境変数自動検証機能:${NC}
    mcp-config.yml（優先順位: ./mcp-config.yml → ~/.dotfiles/mcp-config.yml → 
    ~/.dotfiles/etc/mcp-env-requirements.yml）に定義されたMCPの環境変数要件に基づいて
    自動的に必須環境変数を検証する。

    検証内容:
        - YAMLファイルに定義された必須環境変数が未設定の場合、対話的に入力を求める
        - 入力された値は自動的に -e オプションとして claude mcp add-json コマンドに渡される

    YAMLファイル形式:
        \"@modelcontextprotocol/server-gitlab\":
            - GITLAB_PERSONAL_ACCESS_TOKEN
            - GITLAB_API_URL

${BOLD}MCPサービスの使用例:${NC}
    ${DIMMED}# playwrightサービスを起動してClaudeを実行${NC}
    $(basename "$0") --mcp playwright

    ${DIMMED}# 複数のMCPサービスを起動${NC}
    $(basename "$0") --mcp memory --mcp playwright

    ${DIMMED}# 終了時にMCPサービスを停止${NC}
    $(basename "$0") --mcp playwright --stop-mcp"
        return 0
    }

# スクリプトが直接実行された場合のみメイン処理を実行
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    ccc_main "$@"
    exit $?
fi
