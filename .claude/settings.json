{
  "env": {
      "MCP_TIMEOUT": "20000",
      "MCP_TOOL_TIMEOUT": "20000",
      "DISABLE_TELEMETRY": "1",
      "DISABLE_BUG_COMMAND": "1",
      "DISABLE_AUTOUPDATER": "1",
      "DISABLE_ERROR_REPORTING": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__playwright"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "mcp__playwright__browser_install"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-command.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/git-check.sh"
          }
        ]
      },
      {
        "matcher": "Read|Edit|MultiEdit|Write|Glob|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/file-protection.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] $USER: $(jq -r '.tool_input.command')\" >> ~/.claude/command_history.log"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/code-formatter.sh"
          }
        ]
      }
    ]
  }
}
