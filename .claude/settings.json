{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_TELEMETRY": "1",
    "MCP_TIMEOUT": "5000"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__playwright"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "mcp__playwright__browser_install"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if .tool_input.command | test(\"rm -rf|dd if=|:(){ :|:& };:\") then {\"decision\": \"block\", \"reason\": \"危険なコマンドは実行できません。別の方法を検討してください。\"} else empty end'"
          }
        ]
      },
      {
          "matcher": "Read|Edit|MultiEdit|Write|Glob|Grep|Bash",
          "hooks": [
              {
                  "type": "command",
                  "command": "~/.claude/hooks/file-protection.sh"
              }
          ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] $USER: $(jq -r '.tool_input.command')\" >> ~/.claude/command_history.log"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/code-formatter.sh"
          }
        ]
      }
    ]
  }
}
